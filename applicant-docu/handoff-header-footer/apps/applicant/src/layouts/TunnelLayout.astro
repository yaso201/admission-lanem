---
/**
 * TunnelLayout.astro — Gabarit principal de l'app applicant
 * ---------------------------------------------------------
 * AJOUTS vs version initiale :
 *   • <Header /> rendu pour TOUTES les pages (fin de la duplication du
 *     <header class="site-header"> dans chaque page).
 *   • Prop `footer` : choisit le pied de page selon le type de page.
 *
 * Convention `footer` :
 *   • 'strip' (défaut) → ruban légal minimal. Pour les ÉTAPES du tunnel
 *      qui ont une barre d'action collante (index, identite, bourses,
 *      pieces, recapitulatif, paiement). Voir README pour l'interaction
 *      avec `.action-bar`.
 *   • 'full'  → footer riche. Pour les pages terminales sans barre
 *      d'action (confirmation, suivi, paiement-accepte/echoue/sop).
 *   • 'none'  → aucun footer.
 *
 * La barre de PROGRESSION reste fournie par chaque page (juste sous le
 * header), inchangée.
 */
import '@emela/design-system/index.css';
import '@emela/design-system/palette-ext.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FooterLegalStrip from '../components/FooterLegalStrip.astro';

interface Props {
  title: string;
  footer?: 'full' | 'strip' | 'none';
}
const { title, footer = 'strip' } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&family=JetBrains+Mono:wght@400&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&family=JetBrains+Mono:wght@400&display=swap"
      />
    </noscript>
  </head>
  <body>
    <Header />
    <slot />
    {footer === 'full' && <Footer />}
    {footer === 'strip' && <FooterLegalStrip />}
  </body>
</html>
