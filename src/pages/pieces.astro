---
import TunnelLayout from '../layouts/TunnelLayout.astro';
import { getEntry } from 'astro:content';
const etape = await getEntry('etapes', 'pieces');
---
<TunnelLayout title="Candidature — Pièces justificatives · Étape 3">
<style is:global>

  body { background: var(--cream); -webkit-font-smoothing: antialiased; }
  .ico { width: 18px; height: 18px; flex-shrink: 0; }
  .ico-sm { width: 15px; height: 15px; flex-shrink: 0; }
  .ico-lg { width: 22px; height: 22px; flex-shrink: 0; }

  /* Progress */
  .progress-strip { background: var(--surface-paper); border-bottom: 1px solid var(--border-subtle); }
  .progress-inner { max-width: 1120px; margin: 0 auto; padding: var(--space-4) var(--space-5); display: flex; align-items: center; gap: var(--space-6); }
  .progress-label { font-size: var(--text-sm); font-weight: 600; color: var(--text-primary); white-space: nowrap; }
  .progress-label .num { font-family: var(--font-mono); color: var(--violet); }
  .progress-seg { display: flex; gap: var(--space-3); flex: 1; max-width: 420px; }
  .seg { height: 5px; flex: 1; border-radius: 999px; background: var(--sand-200); }
  .seg.is-done { background: var(--violet); }
  .seg.is-current { background: var(--violet); }
  .progress-steps-text { font-size: var(--text-sm); color: var(--text-tertiary); white-space: nowrap; display: none; }

  /* Layout */
  .tunnel { max-width: 1120px; margin: 0 auto; padding: var(--space-8) var(--space-5); display: grid; grid-template-columns: 1fr; gap: var(--space-8); align-items: start; }

  /* Anchor */
  .lede { position: static; background: var(--violet); color: #fff; border-radius: var(--radius-xl); padding: var(--space-8) var(--space-7); }
  .lede-eyebrow { display: block; margin-bottom: var(--space-4); color: var(--gold); }
  .lede h1 { font-family: var(--font-display); font-size: var(--text-2xl); font-weight: 700; letter-spacing: -0.02em; line-height: 1.08; color: #fff; }
  .lede p { margin-top: var(--space-5); font-size: var(--text-md); color: rgba(255,255,255,0.80); text-wrap: pretty; }
  .lede-points { margin-top: var(--space-7); display: flex; flex-direction: column; gap: var(--space-5); padding-top: var(--space-6); border-top: 1px solid rgba(255,255,255,0.16); }
  .lede-point { display: flex; gap: var(--space-4); align-items: flex-start; font-size: var(--text-sm); color: rgba(255,255,255,0.74); }
  .lede-point svg { color: var(--gold); flex-shrink: 0; margin-top: 1px; }
  .lede-point strong { color: #fff; font-weight: 600; display: block; }

  /* Summary strip */
  .summary { background: var(--surface-paper); border: 1px solid var(--border-default); border-radius: var(--radius-md); padding: var(--space-5) var(--space-6); margin-bottom: var(--space-7); }
  .summary-top { display: flex; align-items: center; justify-content: space-between; gap: var(--space-4); margin-bottom: var(--space-4); }
  .summary-count { font-size: var(--text-base); font-weight: 600; color: var(--text-primary); }
  .summary-count .n { color: var(--violet); }
  .summary-note { font-size: var(--text-xs); color: var(--text-tertiary); }
  .summary-bar { height: 6px; background: var(--sand-200); border-radius: 999px; overflow: hidden; }
  .summary-bar .fill { height: 100%; background: var(--lagoon); border-radius: 999px; }

  /* Document list */
  .doc-list { display: flex; flex-direction: column; gap: var(--space-4); }
  .doc-item { border: 1px solid var(--border-default); border-radius: var(--radius-md); background: var(--surface-paper); overflow: hidden; }
  .doc-item.is-error { border-color: var(--error-100); }
  .doc-top { display: flex; gap: var(--space-4); align-items: flex-start; padding: var(--space-5) var(--space-6); }
  .doc-ic { width: 40px; height: 40px; border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; flex-shrink: 0; background: var(--sand-100); color: var(--sand-600); }
  .doc-ic--done { background: var(--lagoon-soft); color: var(--lagoon-deep); }
  .doc-ic--active { background: var(--violet-soft); color: var(--violet); }
  .doc-ic--error { background: var(--error-50); color: var(--error-700); }
  .doc-info { flex: 1; min-width: 0; }
  .doc-title { font-size: var(--text-base); font-weight: 600; color: var(--text-primary); display: flex; align-items: center; gap: var(--space-3); flex-wrap: wrap; }
  .doc-req { color: var(--error-500); font-weight: 700; }
  .doc-opt { font-size: var(--text-2xs); font-weight: 600; color: var(--text-tertiary); text-transform: uppercase; letter-spacing: 0.06em; }
  .doc-sub { font-size: var(--text-xs); color: var(--text-tertiary); margin-top: 3px; }
  .doc-status { flex-shrink: 0; align-self: flex-start; }
  .doc-body { padding: 0 var(--space-6) var(--space-6); }

  /* Uploaded file row */
  .filerow { display: flex; align-items: center; gap: var(--space-4); padding: var(--space-4) var(--space-5); background: var(--sand-25); border: 1px solid var(--border-subtle); border-radius: var(--radius-sm); }
  .filerow .fi { color: var(--lagoon-deep); flex-shrink: 0; }
  .filerow-body { flex: 1; min-width: 0; display: flex; flex-direction: column; }
  .filerow-name { font-size: var(--text-sm); font-weight: 600; color: var(--text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .filerow-meta { font-size: var(--text-xs); color: var(--text-tertiary); margin-top: 1px; }
  .filerow-actions { display: flex; gap: var(--space-2); flex-shrink: 0; }

  /* Progress (en cours) */
  .uploading { display: flex; flex-direction: column; gap: var(--space-4); }
  .up-bar { height: 8px; background: var(--sand-200); border-radius: 999px; overflow: hidden; }
  .up-bar .fill { height: 100%; background: var(--violet); border-radius: 999px; transition: width var(--duration-normal) var(--ease-out); }
  .up-row { display: flex; align-items: center; justify-content: space-between; gap: var(--space-4); }
  .up-stat { font-size: var(--text-sm); color: var(--text-secondary); font-variant-numeric: tabular-nums; }
  .up-stat strong { color: var(--violet); font-weight: 700; }

  /* Drop zone uses .em-file-drop */
  .em-file-drop { padding: var(--space-7) var(--space-7); }
  .em-file-drop:hover { border-color: var(--violet); background: var(--violet-soft); }
  .em-file-drop-icon { color: var(--violet); }
  .em-file-drop-title .lnk { color: var(--text-link); text-decoration: underline; text-underline-offset: 2px; }

  /* Error */
  .uperror { display: flex; gap: var(--space-4); padding: var(--space-5); background: var(--error-50); border-radius: var(--radius-sm); align-items: flex-start; }
  .uperror svg { color: var(--error-700); flex-shrink: 0; margin-top: 1px; }
  .uperror-body { flex: 1; min-width: 0; }
  .uperror-title { font-size: var(--text-sm); font-weight: 600; color: var(--error-900); }
  .uperror-text { font-size: var(--text-xs); color: var(--error-700); margin-top: 2px; }
  .uperror-actions { margin-top: var(--space-4); display: flex; align-items: center; gap: var(--space-4); }
  .uperror-reassure { font-size: var(--text-xs); color: var(--text-secondary); display: inline-flex; align-items: center; gap: var(--space-2); }

  /* Action bar */
  .action-bar { position: sticky; bottom: 0; z-index: var(--z-sticky); background: var(--surface-paper); border-top: 1px solid var(--border-default); box-shadow: 0 -8px 24px -16px rgba(15,14,10,0.18); }
  .action-bar-inner { max-width: 1120px; margin: 0 auto; padding: var(--space-4) var(--space-5); display: flex; align-items: center; justify-content: space-between; gap: var(--space-4); }
  .ab-left { display: flex; align-items: center; gap: var(--space-5); min-width: 0; }
  .ab-gate { font-size: var(--text-sm); color: var(--text-secondary); display: none; align-items: center; gap: var(--space-3); }
  .ab-gate svg { color: var(--violet); flex-shrink: 0; }
  .ab-right { display: flex; align-items: center; gap: var(--space-4); flex: 1; }
  .ab-right .em-btn--lg { flex: 1; }

  /* Palette overrides */
  .em-btn--primary { background: var(--gold); color: var(--gold-ink); }
  .em-btn--primary:hover { background: var(--gold-deep); color: var(--gold-ink); }
  .em-btn--primary[disabled] { background: var(--gold); color: var(--gold-ink); }
  .em-badge--success { background: var(--lagoon-soft); color: var(--lagoon-deep); }
  .em-badge--success .em-badge-dot { background: var(--lagoon); }
  .em-badge--info { background: var(--violet-soft); color: var(--violet); }
  .em-badge--info .em-badge-dot { background: var(--violet); }

  /* Profil actif + bascule maquette */
  .profil-bar { display: flex; align-items: center; gap: var(--space-4); flex-wrap: wrap; margin-bottom: var(--space-6); padding: var(--space-4) var(--space-5); background: var(--surface-paper); border: 1px solid var(--border-default); border-radius: var(--radius-md); }
  .profil-bar-ic { width: 34px; height: 34px; border-radius: var(--radius-sm); background: var(--violet-soft); color: var(--violet); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .profil-bar-txt { font-size: var(--text-sm); color: var(--text-secondary); flex: 1; min-width: 140px; }
  .profil-bar-txt strong { color: var(--text-primary); font-weight: 600; }
  .profil-switch { display: inline-flex; background: var(--sable); border: 1px solid var(--border-default); border-radius: var(--radius-md); padding: 3px; gap: 3px; }
  .profil-switch button { appearance: none; cursor: pointer; border: 0; background: transparent; font-family: var(--font-sans); font-size: var(--text-xs); font-weight: 600; color: var(--text-secondary); padding: 6px 12px; border-radius: var(--radius-sm); transition: all var(--duration-fast) var(--ease-out); white-space: nowrap; }
  .profil-switch button:hover { color: var(--text-primary); }
  .profil-switch button.is-active { background: var(--surface-paper); color: var(--violet); box-shadow: var(--shadow-xs); }

  /* Bandeau ACO (admission conditionnelle) */
  .aco-banner { display: flex; gap: var(--space-4); align-items: flex-start; padding: var(--space-5) var(--space-6); background: var(--accent-50); border: 1px solid var(--accent-200); border-radius: var(--radius-md); margin-bottom: var(--space-6); }
  .aco-banner[hidden] { display: none; }
  .aco-banner svg { color: var(--ochre); flex-shrink: 0; margin-top: 1px; }
  .aco-banner-title { font-size: var(--text-sm); font-weight: 700; color: var(--clay-deep); }
  .aco-banner-text { font-size: var(--text-xs); color: var(--clay-deep); margin-top: 2px; line-height: var(--leading-normal); }
  .doc-opt-soft { color: var(--text-tertiary); }

  /* ---- Media queries mobile-first ---- */
  @media (min-width: 480px) {
    .progress-steps-text { display: block; }
    .progress-inner { padding: var(--space-4) var(--space-8); }
    .action-bar-inner { padding: var(--space-5) var(--space-8); gap: var(--space-5); }
    .ab-right { flex: initial; }
    .ab-right .em-btn--lg { flex: initial; }
  }

  @media (min-width: 768px) {
    .tunnel { grid-template-columns: 340px 1fr; gap: var(--space-11); padding: var(--space-10) var(--space-8); }
    .lede { position: sticky; top: 120px; padding: var(--space-9) var(--space-8); }
    .lede h1 { font-size: var(--text-3xl); }
    .ab-gate { display: inline-flex; }
  }

</style>


