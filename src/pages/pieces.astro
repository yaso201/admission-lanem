<div class="progress-strip">
  <div class="progress-inner">
    <span class="progress-label"><span class="num">3</span> / 4 — Pièces</span>
    <div class="progress-seg" role="progressbar" aria-valuenow="3" aria-valuemin="0" aria-valuemax="4" aria-label="Étape 3 sur 4 : Pièces">
      <span class="seg is-done"></span>
      <span class="seg is-done"></span>
      <span class="seg is-current"></span>
      <span class="seg"></span>
    </div>
    <span class="progress-steps-text">Suivant&nbsp;: Récapitulatif</span>
  </div>
</div>

<main class="tunnel" id="main">
  <!-- Anchor -->
  <aside class="lede">
    <span class="t-overline lede-eyebrow">{etape.data.eyebrow}</span>
    <h1>{etape.data.titre}</h1>
    <p>{etape.data.description}</p>
    <div class="lede-points">
      {etape.data.points.map(pt => (
        <div class="lede-point">
          <svg class="ico-lg"><use href={`#${pt.icon}`}/></svg>
          <span><strong>{pt.titre}</strong>{pt.detail}</span>
        </div>
      ))}
    </div>
  </aside>

  <!-- Documents column -->
  <div>
    <div class="profil-bar">
      <span class="profil-bar-ic"><svg class="ico-lg"><use href="#i-cap"/></svg></span>
      <span class="profil-bar-txt">Pièces adaptées à votre profil&nbsp;: <strong id="pb-label">…</strong></span>
      <span class="em-badge em-badge--info" id="pb-dossier">Dossier —</span>
    </div>

    <div class="aco-banner" id="aco-banner" hidden>
      <svg class="ico-lg"><use href="#i-info"/></svg>
      <span>
        <span class="aco-banner-title">Candidature sous réserve d'obtention du Bac</span>
        <span class="aco-banner-text">Vous candidatez avec vos relevés de Terminale. En cas d'admission, elle sera conditionnelle (ACO)&nbsp;: vous fournirez votre diplôme via le complément de dossier, et la condition sera levée après vérification par l'établissement.</span>
      </span>
    </div>

    <div class="summary">
      <div class="summary-top">
        <span class="summary-count"><span class="n" id="sum-done">0</span> sur <span id="sum-total">0</span> pièces obligatoires envoyées</span>
        <span class="summary-note">PDF ou JPG · taille max par pièce</span>
      </div>
      <div class="summary-bar"><div class="fill" id="sum-fill" style="width:0%;"></div></div>
    </div>

    <div class="doc-list" id="doc-list"></div>
  </div>
</main>

<div class="action-bar">
  <div class="action-bar-inner">
    <div class="ab-left">
      <a class="em-btn em-btn--ghost" href="/identite" id="back-pieces"><svg class="ico"><use href="#i-caretleft"/></svg>Retour</a>
      <span class="ab-gate" id="ab-gate"><svg class="ico-sm"><use href="#i-info"/></svg><span id="ab-gate-text">2 pièces obligatoires restantes</span></span>
    </div>
    <div class="ab-right">
      <button type="button" class="em-btn em-btn--primary em-btn--lg" id="ab-next" disabled aria-disabled="true">Continuer vers le récapitulatif<svg class="ico"><use href="#i-caretright"/></svg></button>
    </div>
  </div>
</div>


<script is:inline src="/scripts/admission-tunnel.js"></script>
<script is:inline src="/scripts/admission-profil.js"></script>
<script is:inline>
/* LOT F (F3) — pièces RÉELLES : liste du dossier (get_dossier) + upload binaire direct
   (upload_piece_file, A0.4). Rendu en DOM sûr (textContent) — aucun nom de fichier
   client ni donnée serveur injectés en HTML. */
(function () {
  'use strict';
  var AT = window.AdmissionTunnel;
  var AP = window.AdmissionProfil;
  document.getElementById('back-pieces').href = AT.buildUrl('/identite');
  /* Token de dossier expiré en cours de route → reprise par OTP. */
  AT.onTokenExpired = function () { AT.navigateTo('/reprise'); };

  var listEl = document.getElementById('doc-list');
  var gateText = document.getElementById('ab-gate-text');
  var nextBtn = document.getElementById('ab-next');
  var pieces = [];   // état SERVEUR : [{code,label,statut,requise}]
  var live = {};     // état LOCAL transitoire : code -> {state,pct,message,fileName}
  var bars = {};     // code -> élément .fill (progression sans re-render)

  /* Descriptions UX locales par code de pièce (catalogue front). */
  var subByCode = {};
  Object.keys(AP.PROFILS).forEach(function (k) {
    AP.piecesPour(AP.PROFILS[k]).forEach(function (p) { subByCode[p.id] = p.sub; });
  });

  /* ---- Helpers DOM sûrs ---- */
  function h(tag, cls, text) {
    var e = document.createElement(tag);
    if (cls) { e.className = cls; }
    if (text != null) { e.textContent = text; }
    return e;
  }
  function svgUse(id, cls) {
    var svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
    svg.setAttribute('class', cls || 'ico-lg');
    var use = document.createElementNS('http://www.w3.org/2000/svg', 'use');
    use.setAttribute('href', '#' + id);
    svg.appendChild(use);
    return svg;
  }
  function badge(kind, text) {
    var b = h('span', 'em-badge' + (kind ? ' em-badge--' + kind : ' em-badge--neutral'));
    if (kind === 'success') { b.appendChild(svgUse('i-check', 'ico-sm ico-xs')); }
    b.appendChild(document.createTextNode(text));
    return b;
  }
  function fileInput(code) {
    var input = document.createElement('input');
    input.type = 'file';
    input.accept = '.pdf,.jpg,.jpeg,.png';
    input.addEventListener('change', function () {
      if (input.files && input.files[0]) { startUpload(code, input.files[0]); }
    });
    return input;
  }

  /* ---- Upload (validation client puis multipart, le back revalide tout) ---- */
  function startUpload(code, file) {
    var ext = (file.name.indexOf('.') > -1 ? file.name.split('.').pop() : '').toLowerCase();
    if (['pdf', 'jpg', 'jpeg', 'png'].indexOf(ext) === -1) {
      live[code] = { state: 'error', message: 'Format non accepté — envoyez un PDF, JPG ou PNG.' };
      render(); return;
    }
    if (file.size > 5 * 1024 * 1024) {
      live[code] = { state: 'error', message: 'Fichier trop volumineux (maximum 5 Mo).' };
      render(); return;
    }
    live[code] = { state: 'progress', pct: 0, fileName: file.name };
    render();
    AT.api.uploadPieceFile(code, file, function (res) {
      if (res.ok) {
        delete live[code];
        pieces.forEach(function (p) { if (p.code === code) { p.statut = 'deposee'; } });
      } else if (res.error && res.error.code === 'OTP_RESENT') {
        AT.navigateTo('/reprise');
        return;
      } else {
        live[code] = { state: 'error',
          message: (res.error && res.error.message) || 'Envoi impossible. Vérifiez votre connexion et réessayez.' };
      }
      render();
    }, function (pct) {
      var s = live[code];
      if (s && s.state === 'progress') {
        s.pct = pct;
        if (bars[code]) { bars[code].style.width = pct + '%'; }
      }
    });
  }

  /* ---- Rendu d'une pièce ---- */
  function bodyFor(p, state) {
    var body = h('div', 'doc-body');
    if (state.state === 'deposee') {
      var row = h('div', 'filerow');
      var fi = svgUse('i-file', 'ico-lg fi'); fi.classList.add('fi'); row.appendChild(fi);
      var rb = h('span', 'filerow-body');
      rb.appendChild(h('span', 'filerow-name', 'Pièce enregistrée'));
      rb.appendChild(h('span', 'filerow-meta', 'Reçue par le service des admissions.'));
      row.appendChild(rb);
      var actions = h('span', 'filerow-actions');
      var replaceBtn = h('button', 'em-btn em-btn--secondary em-btn--sm', 'Remplacer');
      replaceBtn.type = 'button';
      var input = fileInput(p.code);
      input.hidden = true;
      replaceBtn.addEventListener('click', function () { input.click(); });
      actions.appendChild(replaceBtn);
      actions.appendChild(input);
      row.appendChild(actions);
      body.appendChild(row);
    } else if (state.state === 'progress') {
      var up = h('div', 'uploading');
      up.setAttribute('role', 'status'); up.setAttribute('aria-live', 'polite');
      var bar = h('div', 'up-bar');
      var fill = h('div', 'fill'); fill.style.width = (state.pct || 0) + '%';
      bars[p.code] = fill;
      bar.appendChild(fill); up.appendChild(bar);
      var rowUp = h('div', 'up-row');
      var stat = h('span', 'up-stat');
      stat.appendChild(h('strong', null, 'Envoi en cours'));
      stat.appendChild(document.createTextNode(' · ' + (state.fileName || '')));
      rowUp.appendChild(stat); up.appendChild(rowUp);
      body.appendChild(up);
    } else if (state.state === 'error') {
      var err = h('div', 'uperror');
      err.setAttribute('role', 'alert');
      err.appendChild(svgUse('i-warning', 'ico-lg'));
      var eb = h('span', 'uperror-body');
      eb.appendChild(h('span', 'uperror-title', 'L’envoi a échoué.'));
      eb.appendChild(h('span', 'uperror-text', state.message || ''));
      var ea = h('span', 'uperror-actions');
      var retry = h('button', 'em-btn em-btn--secondary', null);
      retry.type = 'button';
      retry.appendChild(svgUse('i-retry', 'ico-sm'));
      retry.appendChild(document.createTextNode('Réessayer'));
      var input2 = fileInput(p.code);
      input2.hidden = true;
      retry.addEventListener('click', function () { input2.click(); });
      ea.appendChild(retry); ea.appendChild(input2);
      eb.appendChild(ea);
      err.appendChild(eb);
      body.appendChild(err);
    } else {
      var drop = h('label', 'em-file-drop');
      drop.appendChild(fileInput(p.code));
      var ic = h('span', 'em-file-drop-icon'); ic.appendChild(svgUse('i-upload', 'ico-lg ico-26')); drop.appendChild(ic);
      var title = h('span', 'em-file-drop-title', 'Prenez une photo ou ');
      title.appendChild(h('span', 'lnk', 'parcourez vos fichiers'));
      drop.appendChild(title);
      drop.appendChild(h('span', 'em-file-drop-hint', subByCode[p.code] || 'PDF, JPG ou PNG — 5 Mo max.'));
      body.appendChild(drop);
    }
    return body;
  }

  function stateFor(p) {
    if (live[p.code]) { return live[p.code]; }
    return { state: p.statut === 'deposee' ? 'deposee' : 'attente' };
  }

  function render() {
    bars = {};
    listEl.textContent = '';
    pieces.forEach(function (p) {
      var state = stateFor(p);
      var item = h('div', 'doc-item' + (state.state === 'error' ? ' is-error' : ''));
      var top = h('div', 'doc-top');
      var icCls = state.state === 'deposee' ? 'doc-ic doc-ic--done'
        : state.state === 'progress' ? 'doc-ic doc-ic--active'
        : state.state === 'error' ? 'doc-ic doc-ic--error' : 'doc-ic';
      var ic = h('span', icCls); ic.appendChild(svgUse('i-file')); top.appendChild(ic);
      var info = h('span', 'doc-info');
      var title = h('span', 'doc-title', p.label);
      if (p.requise) {
        var req = h('span', 'doc-req', ' *'); req.setAttribute('aria-hidden', 'true');
        title.appendChild(req);
      } else {
        title.appendChild(h('span', 'doc-opt', ' · optionnel'));
      }
      info.appendChild(title);
      info.appendChild(h('span', 'doc-sub', subByCode[p.code] || ''));
      top.appendChild(info);
      var st = h('span', 'doc-status');
      if (state.state === 'deposee') { st.appendChild(badge('success', 'Envoyée')); }
      else if (state.state === 'progress') { st.appendChild(badge('info', 'Envoi…')); }
      else if (state.state === 'error') { st.appendChild(badge('error', 'Échec')); }
      else { st.appendChild(badge(null, 'En attente')); }
      top.appendChild(st);
      item.appendChild(top);
      item.appendChild(bodyFor(p, state));
      listEl.appendChild(item);
    });

    var req = pieces.filter(function (p) { return p.requise; });
    var done = req.filter(function (p) { return stateFor(p).state === 'deposee'; }).length;
    var total = req.length;
    var remaining = total - done;
    document.getElementById('sum-done').textContent = done;
    document.getElementById('sum-total').textContent = total;
    document.getElementById('sum-fill').style.width = (total ? Math.round(done / total * 100) : 0) + '%';

    if (remaining > 0) {
      gateText.textContent = remaining + ' pièce' + (remaining > 1 ? 's' : '') + ' obligatoire' + (remaining > 1 ? 's' : '') + ' restante' + (remaining > 1 ? 's' : '');
      nextBtn.setAttribute('disabled', '');
      nextBtn.setAttribute('aria-disabled', 'true');
      nextBtn.onclick = null;
    } else {
      gateText.textContent = 'Toutes les pièces obligatoires sont envoyées';
      nextBtn.removeAttribute('disabled');
      nextBtn.setAttribute('aria-disabled', 'false');
      nextBtn.onclick = function () { AT.navigateTo('/recapitulatif'); };
    }
  }

  function showBlocked(message) {
    listEl.textContent = '';
    var box = h('div', 'uperror');
    box.setAttribute('role', 'alert');
    box.appendChild(svgUse('i-warning', 'ico-lg'));
    var eb = h('span', 'uperror-body');
    eb.appendChild(h('span', 'uperror-title', message));
    var ea = h('span', 'uperror-actions');
    var link = h('a', 'em-btn em-btn--secondary', 'Reprendre mon dossier');
    link.href = '/reprise';
    ea.appendChild(link);
    eb.appendChild(ea);
    box.appendChild(eb);
    listEl.appendChild(box);
  }

  /* ---- Chargement initial : la liste des pièces vient du DOSSIER (back) ---- */
  if (!AT.getDossierId() || !AT.getDossierToken()) {
    document.getElementById('pb-label').textContent = '—';
    showBlocked('Aucun dossier en cours sur cet appareil.');
    return;
  }
  AT.api.getDossier(function (res) {
    if (!res.ok) {
      if (res.error && res.error.code === 'OTP_RESENT') { AT.navigateTo('/reprise'); return; }
      showBlocked((res.error && res.error.message) || 'Impossible de charger votre dossier.');
      return;
    }
    var d = res.data;
    pieces = d.pieces || [];
    document.getElementById('pb-dossier').textContent = 'Dossier ' + d.dossier_id;
    var profilId = String(d.profil_bac || '').replace(/^bac_/, '');
    var profil = AP.PROFILS[profilId];
    document.getElementById('pb-label').textContent = profil ? profil.label : (d.profil_bac || '—');
    document.getElementById('aco-banner').hidden = !d.conditionnel;
    render();
  });
})();
</script>

</TunnelLayout>
