---
import TunnelLayout from '../layouts/TunnelLayout.astro';
---
<TunnelLayout title="Suivi de candidature" footer="full">
<style is:global>

  body { background: var(--cream); -webkit-font-smoothing: antialiased; }
  .ico { width: 18px; height: 18px; flex-shrink: 0; }
  .ico-sm { width: 15px; height: 15px; flex-shrink: 0; }
  .ico-lg { width: 22px; height: 22px; flex-shrink: 0; }

  .suivi { max-width: 680px; margin: 0 auto; padding: var(--space-8) var(--space-5); }
  .suivi-eyebrow { display: block; margin-bottom: var(--space-3); color: var(--violet); }
  .suivi h1 { font-family: var(--font-display); font-size: var(--text-2xl); font-weight: 700; letter-spacing: -0.02em; color: var(--text-primary); margin-bottom: var(--space-7); }

  /* Status anchor card (violet) */
  .status-card { background: var(--violet); color: #fff; border-radius: var(--radius-xl); padding: var(--space-7); }
  .status-top { display: flex; align-items: flex-start; justify-content: space-between; gap: var(--space-5); flex-wrap: wrap; }
  .status-prog { font-size: var(--text-lg); font-weight: 700; }
  .status-name { font-size: var(--text-sm); color: rgba(255,255,255,0.74); margin-top: 2px; }
  .status-badge { display: inline-flex; align-items: center; gap: var(--space-3); padding: 6px 12px; border-radius: 999px; background: rgba(255,255,255,0.14); color: #fff; font-size: var(--text-sm); font-weight: 600; white-space: nowrap; }
  .status-badge .d { width: 7px; height: 7px; border-radius: 50%; background: var(--gold); }
  .status-meta { margin-top: var(--space-6); padding-top: var(--space-5); border-top: 1px solid rgba(255,255,255,0.16); display: flex; flex-wrap: wrap; gap: var(--space-3) var(--space-7); font-size: var(--text-sm); color: rgba(255,255,255,0.74); }
  .status-meta span { display: inline-flex; align-items: center; gap: var(--space-3); }
  .status-meta .num { font-family: var(--font-mono); color: #fff; white-space: nowrap; }

  .card { background: var(--surface-paper); border: 1px solid var(--border-default); border-radius: var(--radius-lg); overflow: hidden; margin-top: var(--space-5); }
  .card-head { padding: var(--space-5) var(--space-6); border-bottom: 1px solid var(--border-subtle); background: var(--sand-25); font-size: var(--text-sm); font-weight: 600; color: var(--text-primary); }
  .card-body { padding: var(--space-6); }

  /* Timeline */
  .timeline { display: flex; flex-direction: column; }
  .tl-row { display: flex; gap: var(--space-5); padding-bottom: var(--space-7); position: relative; }
  .tl-row:last-child { padding-bottom: 0; }
  .tl-row::before { content: ''; position: absolute; left: 17px; top: 36px; bottom: -4px; width: 2px; background: var(--sand-200); }
  .tl-row:last-child::before { display: none; }
  .tl-row.is-done::before { background: var(--lagoon); }
  .tl-dot { width: 36px; height: 36px; border-radius: 50%; flex-shrink: 0; display: flex; align-items: center; justify-content: center; z-index: 1; }
  .tl-row.is-done .tl-dot { background: var(--lagoon-soft); color: var(--lagoon-deep); }
  .tl-row.is-current .tl-dot { background: var(--violet-soft); color: var(--violet); border: 1.5px solid var(--violet); }
  .tl-row.is-future .tl-dot { background: var(--surface-paper); color: var(--sand-500); border: 1.5px solid var(--border-strong); }
  .tl-body { padding-top: 4px; flex: 1; min-width: 0; }
  .tl-name { font-size: var(--text-base); font-weight: 600; color: var(--text-primary); display: flex; align-items: center; gap: var(--space-3); flex-wrap: wrap; }
  .tl-row.is-future .tl-name { color: var(--text-tertiary); font-weight: 500; }
  .tl-date { font-size: var(--text-xs); color: var(--text-tertiary); margin-top: 3px; }
  .tl-now-badge { font-size: var(--text-2xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--violet); background: var(--violet-soft); padding: 2px 8px; border-radius: 999px; }
  .tl-now-badge--cond { color: var(--accent-700); background: var(--accent-100); }

  /* Docs checklist */
  .docs { display: flex; flex-direction: column; gap: var(--space-4); }
  .doc-row { display: flex; align-items: center; gap: var(--space-4); font-size: var(--text-sm); }
  .doc-row .ck { width: 22px; height: 22px; border-radius: 50%; background: var(--lagoon-soft); color: var(--lagoon-deep); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .doc-row .nm { font-weight: 500; color: var(--text-primary); }
  .doc-row .st { margin-left: auto; font-size: var(--text-xs); color: var(--lagoon-deep); font-weight: 600; text-align: right; }
  .doc-row.is-await .ck { background: var(--accent-100); color: var(--accent-700); }
  .doc-row.is-await .st { color: var(--accent-700); }

  .ro-note { margin-top: var(--space-7); display: flex; gap: var(--space-3); align-items: center; justify-content: center; font-size: var(--text-xs); color: var(--text-tertiary); text-align: center; }
  .ro-note svg { flex-shrink: 0; }

  /* Carte d'action contextuelle (ACO / INC / ACC / REF / INS) */
  .status-badge.is-aco { background: rgba(245,158,11,0.22); }
  .status-badge.is-aco .d { background: var(--gold); }

  .aco-card { margin-top: var(--space-5); background: var(--accent-50); border: 1.5px solid var(--gold); border-radius: var(--radius-xl); padding: var(--space-6); }
  @media (min-width: 480px) { .suivi { padding: var(--space-10) var(--space-7) var(--space-12); } .status-card { padding: var(--space-7) var(--space-8); } .aco-card { padding: var(--space-7) var(--space-8); } }
  .aco-card-top { display: flex; gap: var(--space-4); align-items: flex-start; }
  .aco-card-ic { width: 44px; height: 44px; border-radius: var(--radius-md); background: var(--accent-100); color: var(--accent-700); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .aco-card-head { flex: 1; min-width: 0; display: flex; flex-direction: column; }
  .aco-card-kicker { font-size: var(--text-2xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--accent-700); }
  .aco-card-title { font-family: var(--font-display); font-size: var(--text-lg); font-weight: 700; color: var(--clay-deep); margin-top: 2px; }
  .aco-card-text { font-size: var(--text-sm); color: var(--clay-deep); margin-top: var(--space-3); line-height: var(--leading-normal); }
  .aco-steps { margin-top: var(--space-5); padding-top: var(--space-5); border-top: 1px solid #F1DDBF; display: flex; flex-direction: column; gap: var(--space-4); }
  .aco-step { display: flex; gap: var(--space-3); font-size: var(--text-sm); color: var(--clay-deep); align-items: flex-start; line-height: var(--leading-normal); }
  .aco-step svg { color: var(--ochre); flex-shrink: 0; margin-top: 2px; }
  .aco-step strong { font-weight: 700; }
  .aco-actions { margin-top: var(--space-6); display: flex; gap: var(--space-4); flex-wrap: wrap; align-items: center; }
  .aco-actions .em-btn--primary { background: var(--gold); color: var(--gold-ink); }
  .aco-actions .em-btn--primary:hover { background: var(--gold-deep); color: var(--gold-ink); }
  .aco-hint { font-size: var(--text-xs); color: var(--clay-deep); display: inline-flex; align-items: center; gap: var(--space-2); }

  /* Variante succès (ACC / INS) et neutre (REF) */
  .aco-card.is-success { background: var(--lagoon-soft); border-color: var(--lagoon); }
  .aco-card.is-success .aco-card-ic { background: rgba(14,124,134,0.14); color: var(--lagoon-deep); }
  .aco-card.is-success .aco-card-kicker { color: var(--lagoon-deep); }
  .aco-card.is-success .aco-card-title,
  .aco-card.is-success .aco-card-text,
  .aco-card.is-success .aco-step { color: var(--lagoon-deep); }
  .aco-card.is-success .aco-steps { border-top-color: rgba(14,124,134,0.25); }
  .aco-card.is-neutral { background: var(--sand-25); border-color: var(--border-strong); }
  .aco-card.is-neutral .aco-card-ic { background: var(--sand-100); color: var(--sand-600); }
  .aco-card.is-neutral .aco-card-kicker { color: var(--text-tertiary); }
  .aco-card.is-neutral .aco-card-title, .aco-card.is-neutral .aco-card-text { color: var(--text-primary); }

  /* Offre frais 2 (ACC) */
  .ofr-amount { display: flex; align-items: baseline; gap: var(--space-3); margin-top: var(--space-4); }
  .ofr-amount .v { font-family: var(--font-display); font-size: 30px; font-weight: 700; color: var(--lagoon-deep); }
  .ofr-amount .c { font-size: var(--text-sm); color: var(--lagoon-deep); font-weight: 600; }
  .ofr-field { margin-top: var(--space-5); }
  .ofr-field label { display: block; font-size: var(--text-xs); font-weight: 600; color: var(--lagoon-deep); margin-bottom: var(--space-2); }
  .ofr-field input { width: 100%; max-width: 240px; }
  .consent-row { display: flex; gap: var(--space-3); align-items: flex-start; font-size: var(--text-xs); color: var(--lagoon-deep); line-height: var(--leading-normal); margin-top: var(--space-4); }
  .consent-row input[type="checkbox"] { width: 16px; height: 16px; margin-top: 1px; flex-shrink: 0; accent-color: var(--lagoon-deep); }
  .consent-row a { color: inherit; text-decoration: underline; text-underline-offset: 2px; }
  .ofr-channels { margin-top: var(--space-6); display: flex; gap: var(--space-4); flex-wrap: wrap; }

  .act-msg { margin-top: var(--space-5); font-size: var(--text-sm); }
  .act-msg.is-error { color: var(--terra, #B3261E); }
  .act-msg.is-ok { color: var(--lagoon-deep); }

  /* État bloqué (pas de dossier) */
  .blocked { margin-top: var(--space-6); padding: var(--space-7); background: var(--surface-paper); border: 1px solid var(--border-default); border-radius: var(--radius-xl); text-align: center; }
  .blocked p { font-size: var(--text-sm); color: var(--text-secondary); margin-bottom: var(--space-5); }
  .em-btn--primary { background: var(--gold); color: var(--gold-ink); }
  .em-btn--primary:hover { background: var(--gold-deep); color: var(--gold-ink); }

</style>


