</svg>

<div class="progress-strip">
  <div class="progress-inner">
    <span class="progress-label"><span class="num">1</span> / <span id="step-total">4</span> — Formation</span>
    <div class="progress-seg" id="prog-seg" role="progressbar" aria-valuenow="1" aria-valuemin="0" aria-valuemax="4" aria-label="Étape 1 : Formation">
      <span class="seg is-current"></span>
      <span class="seg"></span>
      <span class="seg"></span>
      <span class="seg"></span>
    </div>
    <span class="progress-steps-text" id="prog-next">Suivant&nbsp;: Identité · Pièces · Récapitulatif</span>
  </div>
</div>

<main class="tunnel" id="main">
  <!-- Colonne éditoriale gauche (de B) -->
  <aside class="lede">
    <span class="t-overline lede-eyebrow">{etape.data.eyebrow}</span>
    <h1>{etape.data.titre}</h1>
    <p>{etape.data.description}</p>
    <div class="lede-points">
      {etape.data.points.map(pt => (
        <div class="lede-point">
          <svg class="ico-lg"><use href={`#${pt.icon}`}/></svg>
          <span><strong>{pt.titre}</strong>{pt.detail}</span>
        </div>
      ))}
    </div>
  </aside>

  <!-- Colonne formulaire droite (corps de A) -->
  <div>
    <div class="sec">
      <div class="sec-kicker"><span class="n">1</span>Votre formation</div>
      <div class="em-field">
        <label class="sr-only" for="programme">Programme souhaité</label>
        <select class="em-select" id="programme" aria-required="true">
          <option value="">Chargement des programmes…</option>
        </select>
        <span class="em-field-help">Vous pourrez changer de formation tant que la candidature n'est pas soumise.</span>
        <p class="prog-choice" id="prog-choice" hidden></p>
      </div>
    </div>

    <div class="sec">
      <div class="sec-kicker"><span class="n">2</span>Votre session</div>
      <p class="sec-sub" id="sess-sub">Sessions ouvertes pour <strong id="sess-prog">—</strong>.</p>

      <div class="session-list" role="radiogroup" aria-label="Session de candidature" id="session-list"></div>

      <div class="reassure">
        <svg class="ico-lg"><use href="#i-info"/></svg>
        <p><strong>Le test d'admission</strong> évalue les prérequis de la formation. La date vous sera confirmée par email après l'étude de votre dossier — aucune inscription au test n'est requise dès maintenant.</p>
      </div>

      <!-- Carte récap : pièces à fournir + frais -->
      <div class="preview">
        <div class="preview-head">
          <span class="phc"><svg class="ico-lg"><use href="#i-checklist"/></svg></span>
          <span>
            <span class="ph-title">Pour cette formation, voici ce qu'il faut prévoir</span>
            <span class="ph-sub">Préparez ces pièces (PDF ou JPG). Vous les déposerez à l'étape 3.</span>
          </span>
        </div>
        <div class="preview-body">
          <div>
            <div class="pv-title">Pièces à fournir</div>
            <div class="pv-docs">
              <div class="pv-doc"><svg class="ico-sm"><use href="#i-file"/></svg><span class="nm">Pièce d'identité (CNI ou passeport)</span><span class="tag">Obligatoire</span></div>
              <div class="pv-doc"><svg class="ico-sm"><use href="#i-file"/></svg><span class="nm">Diplôme ou attestation du Bac</span><span class="tag">Obligatoire</span></div>
              <div class="pv-doc"><svg class="ico-sm"><use href="#i-file"/></svg><span class="nm">Relevés de notes (2 dernières années)</span><span class="tag">Obligatoire</span></div>
              <div class="pv-doc"><svg class="ico-sm"><use href="#i-file"/></svg><span class="nm">Curriculum Vitae</span><span class="tag">Obligatoire</span></div>
              <div class="pv-doc"><svg class="ico-sm"><use href="#i-file"/></svg><span class="nm">Lettre de motivation</span><span class="tag opt">Optionnel</span></div>
            </div>
          </div>
          <div class="fee-box">
            <div class="fee-label">Frais de candidature</div>
            <div class="fee-amount"><span id="fee-frais1">…</span><span class="cur">FCFA</span></div>
            <div class="fee-note"><svg class="ico-sm"><use href="#i-wallet"/></svg><span>À régler en ligne après vérification de votre dossier. Non remboursables.</span></div>
          </div>
        </div>
      </div>
    </div>

    <div class="sec" id="sec-bourse">
      <div class="sec-kicker"><span class="n">3</span>Bourse d'études</div>
      <p class="sec-sub" id="bourse-sub">Ce parcours est éligible à notre programme de bourses. Souhaitez-vous y candidater&nbsp;?</p>

      <div id="bourse-eligible">
        <div class="bourse-toggle" role="radiogroup" aria-label="Candidater à une bourse">
          <button type="button" class="bt-opt is-active" data-bourse="non" aria-pressed="true">Non, pas pour le moment</button>
          <button type="button" class="bt-opt" data-bourse="oui" aria-pressed="false">Oui, je veux candidater</button>
        </div>
        <div class="bourse-hint" id="bourse-hint">
          <svg class="ico"><use href="#i-info"/></svg>
          <p>Vous pourrez <strong>coller votre simulation</strong> ou choisir vos bourses à l'étape suivante. Les bourses se cumulent jusqu'à <strong>50&nbsp;% de réduction</strong> sur la scolarité.</p>
        </div>
      </div>

      <div class="bourse-inelig" id="bourse-inelig" hidden>
        <svg class="ico"><use href="#i-info"/></svg>
        <p>Cette formation n'est <strong>pas éligible aux bourses</strong> pour la session sélectionnée.</p>
      </div>
    </div>
  </div>
</main>

<div class="action-bar">
  <div class="action-bar-inner">
    <span class="save-chip">
      <span class="ok"><svg><use href="#i-checkcircle"/></svg>Enregistré</span>
      <span class="recap">· <span id="recap-prog">—</span> · <strong id="recap-sess">—</strong></span>
    </span>
    <a id="cta-next" href="/identite" class="em-btn em-btn--primary em-btn--lg">Continuer vers l'identité<svg class="ico"><use href="#i-caretright"/></svg></a>
  </div>
</div>

<script is:inline src="/scripts/admission-tunnel.js"></script>
<script is:inline src="/scripts/programme-options.js"></script>
<script is:inline>
/* LOT F (F8) — programmes et sessions RÉELS (list_programmes / list_sessions) :
   le ctx.session transmis au tunnel est un id de session back valide, et les
   échéances de dépôt affichées sont les closes_on du catalogue. Rendu DOM sûr. */
(function(){
  'use strict';
  var AT = window.AdmissionTunnel;
  var sel = document.getElementById('programme');
  var listEl = document.getElementById('session-list');
  var subProg = document.getElementById('sess-prog');
  var recapProg = document.getElementById('recap-prog');
  var recapSess = document.getElementById('recap-sess');
  var elig = document.getElementById('bourse-eligible');
  var inelig = document.getElementById('bourse-inelig');
  var sub = document.getElementById('bourse-sub');
  var hint = document.getElementById('bourse-hint');
  var toggle = document.querySelector('.bourse-toggle');
  var cta = document.getElementById('cta-next');
  var stepTotal = document.getElementById('step-total');
  var progSeg = document.getElementById('prog-seg');
  var progNext = document.getElementById('prog-next');
  var wantBourse = false;
  var sessions = [];        // sessions du programme sélectionné
  var currentSession = '';  // id back de la session sélectionnée
  var progByCode = {};      // métadonnées catalogue par code (partner/parcours/affinité/lieu)

  function h(tag, cls, text) {
    var e = document.createElement(tag);
    if (cls) { e.className = cls; }
    if (text != null) { e.textContent = text; }
    return e;
  }
  function svgUse(id, cls) {
    var svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
    if (cls) { svg.setAttribute('class', cls); }
    var use = document.createElementNS('http://www.w3.org/2000/svg', 'use');
    use.setAttribute('href', '#' + id);
    svg.appendChild(use);
    return svg;
  }
  function frDate(iso) {
    if (!iso) { return ''; }
    var p = String(iso).split('-');
    var MOIS = ['janv.','févr.','mars','avr.','mai','juin','juil.','août','sept.','oct.','nov.','déc.'];
    return p.length === 3 ? parseInt(p[2], 10) + ' ' + MOIS[parseInt(p[1], 10) - 1] + ' ' + p[0] : iso;
  }
  function parcoursLabel(){
    var pr = progByCode[sel.value];
    return pr ? (pr.label || '') : '';
  }
  function sessionLabel(){
    for (var i = 0; i < sessions.length; i++) {
      if (sessions[i].id === currentSession) { return sessions[i].label; }
    }
    return '—';
  }
  /* Label de choix SOUS le select (≠ texte des <option>) : titre · parcours · partenaire (vide → LaNEM) · lieu.
     LaNEM est volontairement conservé ICI, contrairement aux lignes du select où il est masqué. */
  function updateChoiceLabel(){
    var el = document.getElementById('prog-choice');
    if (!el) { return; }
    var pr = progByCode[sel.value];
    if (!pr) { el.hidden = true; return; }
    var bits = [pr.label, pr.parcours || '', pr.partner || 'LaNEM'];
    if (pr.dd_affinity) { bits.push(pr.dd_affinity); }
    if (pr.location) { bits.push(pr.location); }
    el.textContent = bits.filter(Boolean).join(' · ');
    el.hidden = false;
  }

  /* ---- Frais réels (catalogue back) + éligibilité bourses de la session ---- */
  function loadFrais(){
    var el = document.getElementById('fee-frais1');
    if (!el || !currentSession) { return; }
    AT.api.getFrais({ session: currentSession }, function(res){
      el.textContent = (res.ok && res.data && res.data.frais1)
        ? AT.fmtXOF(res.data.frais1.montant_xof) : '—';
      var bourses = res.ok && res.data && res.data.bourses_eligibles;
      var eligible = !!(bourses && bourses.length);
      elig.hidden = !eligible;
      inelig.hidden = eligible;
      sub.style.display = eligible ? '' : 'none';
      if (!eligible) { setToggle('non'); }
    });
  }

  /* ---- Sessions réelles du programme ---- */
  function renderSessions(){
    listEl.textContent = '';
    if (!sessions.length) {
      var empty = h('p', 'sec-sub', 'Aucune session ouverte pour ce programme actuellement.');
      listEl.appendChild(empty);
      currentSession = '';
      syncRecap();
      return;
    }
    sessions.forEach(function (sess, i) {
      var card = h('label', 'session-card' + (sess.id === currentSession ? ' is-selected' : ''));
      card.dataset.session = sess.id;
      var radio = document.createElement('input');
      radio.type = 'radio'; radio.name = 'session'; radio.className = 'sr-only';
      radio.checked = sess.id === currentSession;
      card.appendChild(radio);
      var mark = h('span', 'radio-mark'); mark.setAttribute('aria-hidden', 'true');
      mark.appendChild(svgUse('i-check'));
      card.appendChild(mark);
      var body = h('span', 'session-body');
      body.appendChild(h('span', 'session-name', sess.label + (sess.academic_year ? ' — ' + sess.academic_year : '')));
      var meta = h('span', 'session-meta');
      var m1 = h('span');
      m1.appendChild(svgUse('i-clock', 'ico-sm'));
      m1.appendChild(document.createTextNode('Dépôts jusqu’au ' + frDate(sess.closes_on)));
      meta.appendChild(m1);
      body.appendChild(meta);
      card.appendChild(body);
      var aside = h('span', 'session-aside');
      var badge = h('span', 'em-badge em-badge--success em-badge--sm');
      badge.appendChild(h('span', 'em-badge-dot'));
      badge.appendChild(document.createTextNode('Ouverte'));
      aside.appendChild(badge);
      card.appendChild(aside);
      card.addEventListener('click', function () { selectSession(sess.id); });
      listEl.appendChild(card);
    });
  }
  function selectSession(id){
    currentSession = id;
    Array.prototype.forEach.call(listEl.querySelectorAll('.session-card'), function (c) {
      var on = c.dataset.session === id;
      c.classList.toggle('is-selected', on);
      var r = c.querySelector('input[name="session"]');
      if (r) { r.checked = on; }
    });
    loadFrais();
    syncRecap();
  }
  function loadSessions(){
    var code = sel.value;
    if (!code) { sessions = []; renderSessions(); return; }
    AT.api.listSessions(code, function (res) {
      sessions = (res.ok && res.data && res.data.sessions) || [];
      currentSession = sessions.length ? sessions[0].id : '';
      var n = sessions.length;
      document.getElementById('sess-sub').firstChild.textContent =
        (n > 1 ? n + ' sessions sont ouvertes pour ' : (n === 1 ? 'Une session est ouverte pour ' : 'Sessions pour '));
      renderSessions();
      loadFrais();
      syncRecap();
    });
  }

  /* ---- Progression + CTA ---- */
  function renderProgress(){
    var total = wantBourse ? 5 : 4;
    stepTotal.textContent = total;
    progSeg.textContent = '';
    for (var i = 0; i < total; i++) {
      var seg = h('span', 'seg' + (i === 0 ? ' is-current' : ''));
      progSeg.appendChild(seg);
    }
    progSeg.setAttribute('aria-valuemax', total);
    progNext.textContent = wantBourse
      ? 'Suivant\u00a0: Bourses · Identité · Pièces · Récapitulatif'
      : 'Suivant\u00a0: Identité · Pièces · Récapitulatif';
  }
  function renderCTA(){
    var p = sel.value;
    if (!p || !currentSession) {
      cta.removeAttribute('href');
      cta.style.pointerEvents = 'none';
      cta.style.opacity = '0.55';
      return;
    }
    cta.style.pointerEvents = '';
    cta.style.opacity = '';
    if (wantBourse) {
      cta.href = AT.buildUrl('/bourses', { parcours: p, session: currentSession, bourse: 'oui' });
      cta.firstChild.textContent = 'Continuer vers les bourses';
    } else {
      cta.href = AT.buildUrl('/identite', { parcours: p, session: currentSession, bourse: 'non' });
      cta.firstChild.textContent = "Continuer vers l'identité";
    }
  }
  function syncRecap(){
    var lbl = parcoursLabel();
    if (subProg) { subProg.textContent = lbl || '—'; }
    if (recapProg) { recapProg.textContent = lbl || '—'; }
    if (recapSess) { recapSess.textContent = sessionLabel(); }
    updateChoiceLabel();
    renderProgress();
    renderCTA();
  }
  function setToggle(val){
    wantBourse = (val === 'oui');
    toggle.querySelectorAll('.bt-opt').forEach(function (b) {
      var on = b.dataset.bourse === val;
      b.classList.toggle('is-active', on);
      b.setAttribute('aria-pressed', on);
    });
    hint.classList.toggle('show', wantBourse);
    renderProgress();
    renderCTA();
  }

  sel.addEventListener('change', loadSessions);
  toggle.addEventListener('click', function (e) {
    var b = e.target.closest('.bt-opt');
    if (b) { setToggle(b.dataset.bourse); }
  });

  /* ---- Chargement initial : programmes réels ---- */
  AT.api.listProgrammes(function (res) {
    var progs = (res.ok && res.data && res.data.programmes) || [];
    sel.textContent = '';
    if (!progs.length) {
      var o = document.createElement('option');
      o.value = ''; o.textContent = 'Aucun programme ouvert actuellement';
      sel.appendChild(o);
      syncRecap();
      return;
    }
    progs.forEach(function (pr) { progByCode[pr.code] = pr; });
    /* Groupement par parcours + tri + texte enrichi (logique pure testée). */
    var groups = window.ProgrammeOptions.buildProgrammeGroups(progs);
    var first = true;
    groups.forEach(function (g) {
      var og = document.createElement('optgroup');
      og.label = g.label;
      g.options.forEach(function (opt) {
        var o = document.createElement('option');
        o.value = opt.value;
        o.textContent = opt.text;
        if (first) { o.selected = true; first = false; }
        og.appendChild(o);
      });
      sel.appendChild(og);
    });
    loadSessions();
  });
  syncRecap();
})();
</script>


</TunnelLayout>
