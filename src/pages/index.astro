---
import TunnelLayout from '../layouts/TunnelLayout.astro';
import { getEntry } from 'astro:content';
const etape = await getEntry('etapes', 'formation');
---
<TunnelLayout title="Candidature — Choix de la formation · Direction retenue">
<style is:global>

  body { background: var(--cream); -webkit-font-smoothing: antialiased; }
  [hidden] { display: none !important; }
  .ico { width: 18px; height: 18px; flex-shrink: 0; }
  .ico-sm { width: 15px; height: 15px; flex-shrink: 0; }
  .ico-lg { width: 22px; height: 22px; flex-shrink: 0; }

  /* ---- Progression minimaliste (de B) ---- */
  .progress-strip { background: var(--surface-paper); border-bottom: 1px solid var(--border-subtle); }
  .progress-inner { max-width: 1120px; margin: 0 auto; padding: var(--space-4) var(--space-5); display: flex; align-items: center; gap: var(--space-6); }
  .progress-label { font-size: var(--text-sm); font-weight: 600; color: var(--text-primary); white-space: nowrap; }
  .progress-label .num { font-family: var(--font-mono); color: var(--violet); }
  .progress-seg { display: flex; gap: var(--space-3); flex: 1; max-width: 420px; }
  .seg { height: 5px; flex: 1; border-radius: 999px; background: var(--sand-200); }
  .seg.is-current { background: var(--violet); }
  .progress-steps-text { font-size: var(--text-sm); color: var(--text-tertiary); white-space: nowrap; display: none; }

  /* ---- Layout éditorial 2 colonnes (de B) ---- */
  .tunnel { max-width: 1120px; margin: 0 auto; padding: var(--space-8) var(--space-5); display: grid; grid-template-columns: 1fr; gap: var(--space-8); align-items: start; }

  /* Bloc d'ancrage violet (de B, version enrichie) */
  .lede { position: static; background: var(--violet); color: #fff; border-radius: var(--radius-xl); padding: var(--space-8) var(--space-7); }
  .lede-eyebrow { display: block; margin-bottom: var(--space-4); color: var(--gold); }
  .lede h1 { font-family: var(--font-display); font-size: var(--text-2xl); font-weight: 700; letter-spacing: -0.02em; line-height: 1.08; color: #fff; }
  .lede p { margin-top: var(--space-5); font-size: var(--text-md); color: rgba(255,255,255,0.80); text-wrap: pretty; }
  .lede-points { margin-top: var(--space-7); display: flex; flex-direction: column; gap: var(--space-5); padding-top: var(--space-6); border-top: 1px solid rgba(255,255,255,0.16); }
  .lede-point { display: flex; gap: var(--space-4); align-items: flex-start; font-size: var(--text-sm); color: rgba(255,255,255,0.74); }
  .lede-point svg { color: var(--gold); flex-shrink: 0; margin-top: 1px; }
  .lede-point strong { color: #fff; font-weight: 600; display: block; }

  /* ---- En-têtes de section numérotés (de B) ---- */
  .sec { margin-bottom: var(--space-9); }
  .sec:last-child { margin-bottom: 0; }
  .sec-kicker { font-size: var(--text-2xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-tertiary); display: flex; align-items: center; gap: var(--space-3); margin-bottom: var(--space-5); }
  .sec-kicker .n { width: 20px; height: 20px; border-radius: 50%; background: var(--violet); color: #fff; display: inline-flex; align-items: center; justify-content: center; font-family: var(--font-mono); font-size: 10px; }
  .sec-sub { font-size: var(--text-sm); color: var(--text-secondary); margin: -8px 0 var(--space-5) 0; }
  .sec-sub strong { color: var(--text-primary); font-weight: 600; }

  /* ---- Cartes session (de A, pleinement cliquables) ---- */
  .session-list { display: flex; flex-direction: column; gap: var(--space-4); }
  .session-card {
    position: relative; display: flex; gap: var(--space-4); align-items: flex-start;
    padding: var(--space-5) var(--space-6);
    border: 1.5px solid var(--border-default); border-radius: var(--radius-md);
    background: var(--surface-paper); cursor: pointer;
    transition: border-color var(--duration-fast) var(--ease-out), background var(--duration-fast) var(--ease-out), box-shadow var(--duration-fast) var(--ease-out);
  }
  .session-card:hover { border-color: var(--border-strong); }
  .session-card .radio-mark { width: 22px; height: 22px; flex-shrink: 0; margin-top: 1px; border: 1.5px solid var(--border-strong); border-radius: 50%; display: flex; align-items: center; justify-content: center; transition: all var(--duration-fast) var(--ease-out); }
  .session-card .radio-mark svg { width: 12px; height: 12px; color: #fff; opacity: 0; transform: scale(0.6); transition: all var(--duration-fast) var(--ease-out); }
  .session-body { flex: 1; min-width: 0; }
  .session-name { font-size: var(--text-base); font-weight: 600; color: var(--text-primary); }
  .session-meta { margin-top: var(--space-3); display: flex; flex-wrap: wrap; gap: var(--space-2) var(--space-5); font-size: var(--text-sm); color: var(--text-secondary); }
  .session-meta span { display: inline-flex; align-items: center; gap: var(--space-2); white-space: nowrap; }
  .session-meta svg { color: var(--text-tertiary); }
  .session-aside { flex-shrink: 0; align-self: center; }
  .session-card.is-selected { border-color: var(--violet); background: var(--violet-soft); box-shadow: 0 0 0 1px var(--violet); }
  .session-card.is-selected .radio-mark { background: var(--violet); border-color: var(--violet); }
  .session-card.is-selected .radio-mark svg { opacity: 1; transform: scale(1); }
  .prog-choice { margin-top: 8px; font-size: var(--text-sm); color: var(--text-secondary); font-weight: 500; }
  /* Taille du select formations : 16px mobile (plancher anti-zoom iOS) → 17px desktop. */
  #programme { font-size: var(--text-base); }
  @media (min-width: 768px) { #programme { font-size: var(--text-md); } }

  /* ---- Note rassurante (de A) ---- */
  .reassure { margin-top: var(--space-6); display: flex; gap: var(--space-4); align-items: flex-start; padding: var(--space-5) var(--space-6); background: var(--clay-soft); border: 1px solid #F4DFC8; border-radius: var(--radius-md); }
  .reassure svg { color: var(--clay); flex-shrink: 0; margin-top: 1px; }
  .reassure p { font-size: var(--text-sm); color: var(--clay-deep); line-height: var(--leading-normal); }
  .reassure strong { color: var(--clay-deep); font-weight: 700; }

  /* ---- Barre d'action collante ---- */
  .action-bar { position: sticky; bottom: 0; z-index: var(--z-sticky); background: var(--surface-paper); border-top: 1px solid var(--border-default); box-shadow: 0 -8px 24px -16px rgba(15,14,10,0.18); }
  .action-bar-inner { max-width: 1120px; margin: 0 auto; padding: var(--space-4) var(--space-5); display: flex; align-items: center; justify-content: space-between; gap: var(--space-5); }
  .save-chip { display: inline-flex; align-items: center; gap: var(--space-3); font-size: var(--text-sm); color: var(--text-secondary); }
  .save-chip .ok { display: inline-flex; align-items: center; gap: var(--space-2); color: var(--lagoon-deep); font-weight: 600; }
  .save-chip .ok svg { width: 15px; height: 15px; }
  .save-chip .recap { color: var(--text-secondary); display: none; }
  .save-chip .recap strong { color: var(--text-primary); font-weight: 600; }
  .em-btn--lg { flex: 1; }

  /* ---- Surcharges palette enrichie ---- */
  /* CTA or — énergie */
  .em-btn--primary { background: var(--gold); color: var(--gold-ink); }
  .em-btn--primary:hover { background: var(--gold-deep); color: var(--gold-ink); }
  .em-btn--primary:active { background: var(--gold-deep); }
  /* Badge "Ouverte" → lagon */
  .em-badge--success { background: var(--lagoon-soft); color: var(--lagoon-deep); }
  .em-badge--success .em-badge-dot { background: var(--lagoon); }
  /* Badge "Places limitées" → ocre */
  .em-badge--accent { background: #FBEBD8; color: var(--accent-900); }

  /* ---- Carte « à prévoir » (pièces + frais), fond sable ---- */
  .preview { margin-top: var(--space-8); background: var(--sable); border: 1px solid var(--border-default); border-radius: var(--radius-lg); overflow: hidden; }
  .preview-head { display: flex; gap: var(--space-4); align-items: flex-start; padding: var(--space-5) var(--space-6); border-bottom: 1px solid var(--border-subtle); }
  .preview-head .phc { width: 36px; height: 36px; border-radius: var(--radius-sm); background: var(--violet-soft); color: var(--violet); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .preview-head .ph-title { font-size: var(--text-base); font-weight: 600; color: var(--text-primary); }
  .preview-head .ph-sub { font-size: var(--text-xs); color: var(--text-tertiary); margin-top: 2px; }
  .preview-body { display: grid; grid-template-columns: 1fr; gap: var(--space-6); padding: var(--space-6); align-items: start; }
  .pv-title { font-size: var(--text-2xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-tertiary); margin-bottom: var(--space-4); }
  .pv-docs { display: flex; flex-direction: column; gap: var(--space-3); }
  .pv-doc { display: flex; align-items: center; gap: var(--space-3); font-size: var(--text-sm); color: var(--text-primary); }
  .pv-doc svg { color: var(--violet); flex-shrink: 0; }
  .pv-doc .nm { font-weight: 500; }
  .pv-doc .tag { margin-left: auto; font-size: var(--text-2xs); font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em; color: var(--text-tertiary); }
  .pv-doc .tag.opt { color: var(--text-tertiary); }
  .fee-box { background: var(--surface-paper); border: 1px solid var(--border-default); border-radius: var(--radius-md); padding: var(--space-6); }
  .fee-label { font-size: var(--text-2xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-tertiary); }
  .fee-amount { font-family: var(--font-display); font-size: 30px; font-weight: 700; letter-spacing: -0.02em; color: var(--violet); line-height: 1; margin-top: var(--space-3); }
  .fee-amount .cur { font-size: var(--text-sm); font-weight: 600; color: var(--text-tertiary); margin-left: var(--space-2); }
  .fee-note { font-size: var(--text-xs); color: var(--text-secondary); margin-top: var(--space-4); line-height: var(--leading-normal); padding-top: var(--space-4); border-top: 1px solid var(--border-subtle); display: flex; gap: var(--space-3); align-items: flex-start; }
  .fee-note svg { color: var(--lagoon-deep); flex-shrink: 0; margin-top: 1px; }
  /* ---- Media queries mobile-first ---- */
  @media (min-width: 480px) {
    .progress-steps-text { display: block; }
    .progress-inner { padding: var(--space-4) var(--space-8); }
    .action-bar-inner { padding: var(--space-5) var(--space-8); }
    .em-btn--lg { flex: initial; }
    .save-chip .recap { display: inline; }
  }

  @media (min-width: 768px) {
    .tunnel { grid-template-columns: 340px 1fr; gap: var(--space-11); padding: var(--space-10) var(--space-8); }
    .lede { position: sticky; top: 120px; padding: var(--space-9) var(--space-8); }
    .lede h1 { font-size: var(--text-3xl); }
    .preview-body { grid-template-columns: 1fr 248px; gap: var(--space-7); }
  }

  /* ---- Bourse (étape d'entrée) ---- */
  .bourse-toggle { display: inline-flex; border: 1.5px solid var(--border-default); border-radius: var(--radius-md); overflow: hidden; background: var(--surface-paper); }
  .bourse-toggle .bt-opt { appearance: none; cursor: pointer; font-family: var(--font-sans); font-size: var(--text-sm); font-weight: 600; color: var(--text-secondary); background: transparent; border: 0; padding: 12px 20px; transition: background var(--duration-fast) var(--ease-out), color var(--duration-fast) var(--ease-out); }
  .bourse-toggle .bt-opt + .bt-opt { border-left: 1.5px solid var(--border-default); }
  .bourse-toggle .bt-opt:hover { background: var(--surface-hover); color: var(--text-primary); }
  .bourse-toggle .bt-opt.is-active { background: var(--violet); color: #fff; }
  .bourse-hint { margin-top: var(--space-5); display: none; gap: var(--space-4); align-items: flex-start; padding: var(--space-5) var(--space-6); background: var(--violet-soft); border-radius: var(--radius-md); }
  .bourse-hint.show { display: flex; }
  .bourse-hint svg { color: var(--violet); flex-shrink: 0; margin-top: 1px; }
  .bourse-hint p { font-size: var(--text-sm); color: var(--text-primary); line-height: var(--leading-normal); }
  .bourse-hint strong { color: var(--violet); font-weight: 700; }
  .bourse-inelig { display: flex; gap: var(--space-4); align-items: flex-start; padding: var(--space-5) var(--space-6); background: var(--clay-soft); border: 1px solid #F4DFC8; border-radius: var(--radius-md); }
  .bourse-inelig svg { color: var(--clay); flex-shrink: 0; margin-top: 1px; }
  .bourse-inelig p { font-size: var(--text-sm); color: var(--clay-deep); line-height: var(--leading-normal); }
  .bourse-inelig strong { color: var(--clay-deep); font-weight: 700; }

</style>


