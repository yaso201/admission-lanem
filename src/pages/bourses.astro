  <symbol id="i-shield" viewBox="0 0 256 256"><path d="M208,40H48A16,16,0,0,0,32,56v58.78c0,89.61,75.82,119.34,91,124.39a15.53,15.53,0,0,0,10,0c15.2-5.05,91-34.78,91-124.39V56A16,16,0,0,0,208,40Zm-34.34,69.66-48,48a8,8,0,0,1-11.32,0l-24-24a8,8,0,0,1,11.32-11.32L120,140.69l42.34-42.35a8,8,0,0,1,11.32,11.32Z"/></symbol>
</svg>

<div class="progress-strip">
  <div class="progress-inner">
    <span class="progress-label"><span class="num">2</span> / 5 — Bourse d'études</span>
    <div class="progress-seg" role="progressbar" aria-valuenow="2" aria-valuemin="0" aria-valuemax="5" aria-label="Étape 2 sur 5 : Bourse d'études">
      <span class="seg is-done"></span>
      <span class="seg is-current"></span>
      <span class="seg"></span>
      <span class="seg"></span>
      <span class="seg"></span>
