      <span class="ab-recap"><strong id="ab-pct">0 %</strong> de réduction · <span class="amt" id="ab-amt">…</span> FCFA/an</span>
    </div>
    <a class="em-btn em-btn--primary em-btn--lg" id="cta-bourses-next" href="/identite">Continuer vers l'identité<svg class="ico"><use href="#i-caretright"/></svg></a>
  </div>
</div>

<script is:inline src="/scripts/admission-tunnel.js"></script>
<script is:inline>
/* LOT-A3 (ADM-DEBT-48) — catalogue de bourses, taux, scolarité, plafond, promotions et
   disclaimer chargés depuis le BACK (get_frais : miroirs UF répliqués). Plus AUCUN taux ni
   montant en dur. L'aperçu chiffré reste une ESTIMATION composée à l'affichage à partir des
   seules données serveur (taux/base/cap/promos) + disclaimer versionné du back — le montant
   réel est calculé par UF à l'inscription. Les identifiants de bourses = mirror_keys back. */
(function(){
  var AT = window.AdmissionTunnel;
  var ctx = AT.readCtx();
  var esc = function(s){ return String(s==null?'':s).replace(/[&<>"']/g, function(c){ return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]; }); };
  var fmt = AT.fmtXOF;
  var pct = function(r){ return (Math.round(r*1000)/10) + ' %'; };

  var CAP = 0.5, BASE = null, FIXES = [], PROMOS = [], OPT = {}, CATS = [];
  var selected = {}; // clé = groupe d'exclusivité serveur → mirror_key retenue
  var DESC_DEFAULT = "Taux appliqué sur la scolarité annuelle uniquement. La bourse est demandée à la candidature, instruite par le Responsable et validée par la Direction.";

  var catsEl = document.getElementById('cats');

  /* ---------- Chargement du référentiel (BACK) ---------- */
  function load(){
    AT.api.getFrais(ctx.session ? { session: ctx.session } : {}, function(res){
      if(!res.ok || !res.data){
        catsEl.innerHTML = '<div class="r-empty">Catalogue de bourses indisponible pour le moment. Vous pourrez formuler votre demande pendant la candidature.</div>';
        return;
      }
      var D = res.data;
      BASE = (D.scolarite_annuelle === undefined) ? null : D.scolarite_annuelle;
      CAP = D.scholarship_cap || 0.5;
      FIXES = [];
      if (D.frais1) FIXES.push({ label: "Frais d'étude de dossier", v: D.frais1.montant_xof });
      if (D.frais2) FIXES.push({ label: "Frais d'inscription", v: D.frais2.montant_xof });
      PROMOS = D.promotions_actives || [];
      CATS = D.bourses_eligibles || [];
      OPT = {};
      CATS.forEach(function(c){
        (c.scholarships || []).forEach(function(o){
          OPT[o.mirror_key] = {
            id: o.mirror_key, label: o.scholarship_name, rate: o.rate,
            group: o.exclusivity_group || ('__solo__' + o.mirror_key),
            exclusive: !!o.exclusivity_group, catName: c.category
          };
        });
      });
      var foot = document.getElementById('r-foot');
      if (foot && D.simulation_disclaimer) { foot.textContent = D.simulation_disclaimer; }
      var capChip = document.getElementById('r-cap-text');
      if (capChip) { capChip.textContent = 'Plafonnée à ' + pct(CAP); }
      document.getElementById('r-parcours').textContent =
        (ctx.parcours || 'votre formation').replace(/-/g, ' ');
      renderCats();
      applyFromIds((ctx.bourses || '').split(',').map(function(s){ return s.trim(); }).filter(Boolean));
      render();
    });
  }

  /* ---------- Rendu des catégories (catalogue serveur) ---------- */
  var CAT_ICONS = { Excellence:'i-star', Merite:'i-star', Partenariat:'i-users', Sociale:'i-heart' };
  function renderCats(){
    catsEl.innerHTML = '';
    if(!CATS.length){
      catsEl.innerHTML = '<div class="r-empty">Aucune bourse au catalogue pour cette session.</div>';
      return;
    }
    CATS.forEach(function(cat){
      var hasExclusive = (cat.scholarships || []).some(function(o){ return o.exclusivity_group; });
      var wrap = document.createElement('div');
      wrap.className = 'cat';
      wrap.innerHTML =
        '<div class="cat-head">' +
          '<span class="cat-icon"><svg class="ico-lg"><use href="#' + (CAT_ICONS[cat.category] || 'i-star') + '"/></svg></span>' +
          '<span><span class="cat-name">' + esc(cat.category) + '</span><span class="cat-note">' +
            (hasExclusive ? 'Bourses exclusives entre elles · 1 seule retenue' : 'Cumulables (dans la limite du plafond)') +
          '</span></span>' +
        '</div>';
      var list = document.createElement('div');
      list.className = 'opt-list';
      (cat.scholarships || []).forEach(function(o){
        var card = document.createElement('div');
        card.className = 'opt';
        card.dataset.opt = o.mirror_key;
        card.setAttribute('role','button'); card.setAttribute('tabindex','0');
        card.innerHTML =
          '<span class="check"><svg><use href="#i-check"/></svg></span>' +
          '<span class="opt-body"><span class="opt-name">' + esc(o.scholarship_name) + '</span>' +
          '<span class="opt-badge">' + (o.exclusivity_group ? 'Groupe ' + esc(o.exclusivity_group) : 'Cumulable') + '</span></span>' +
          '<span class="opt-rate">−' + pct(o.rate) + '</span>' +
          '<button type="button" class="q-btn" data-info="' + esc(o.mirror_key) + '" aria-label="En savoir plus">?</button>';
        list.appendChild(card);
      });
      wrap.appendChild(list);
      catsEl.appendChild(wrap);
    });
  }

  function toggleOpt(id){
    var o = OPT[id]; if(!o) return;
    selected[o.group] = (selected[o.group] === id) ? null : id;
    render();
  }

  catsEl.addEventListener('click', function(e){
    var info = e.target.closest('.q-btn');
    if(info){ e.stopPropagation(); openModal(info.dataset.info); return; }
    var card = e.target.closest('.opt');
    if(card) toggleOpt(card.dataset.opt);
  });
  catsEl.addEventListener('keydown', function(e){
    if((e.key===' '||e.key==='Enter') && e.target.classList.contains('opt')){ e.preventDefault(); toggleOpt(e.target.dataset.opt); }
  });

  /* ---------- Aperçu (estimation indicative — données 100 % serveur) ---------- */
  function render(){
    var applied = Object.keys(selected).map(function(g){ return selected[g]; }).filter(Boolean).map(function(id){ return OPT[id]; });
    var raw = applied.reduce(function(s,o){ return s + o.rate; }, 0);
    var capped = Math.min(raw, CAP);
    var isCapped = raw > CAP + 1e-9;
    var promoRate = PROMOS.reduce(function(s,p){ return s + (p.taux !== undefined ? p.taux : p.rate || 0); }, 0);
    var totalRate = Math.min(capped + promoRate, 1);
    var fixesTotal = FIXES.reduce(function(s,f){ return s + (f.v || 0); }, 0);
    var totalDu = (BASE !== null && BASE !== undefined)
      ? Math.max(BASE * (1 - totalRate), 0) + fixesTotal : null;

    document.querySelectorAll('.opt').forEach(function(c){
      var o = OPT[c.dataset.opt];
      c.classList.toggle('is-selected', !!(o && selected[o.group] === c.dataset.opt));
    });

    document.getElementById('r-base').textContent = BASE === null ? '—' : fmt(BASE);
    var linesEl = document.getElementById('r-lines');
    linesEl.innerHTML = applied.length
      ? applied.map(function(o){ return '<div class="r-line minus"><span class="lab">' + esc(o.label) + '</span><span class="val">− ' + pct(o.rate) + '</span></div>'; }).join('')
      : '<div class="r-empty">Aucune bourse sélectionnée pour l\'instant.</div>';
    document.getElementById('r-reduc-pct').textContent = '− ' + pct(capped);
    document.getElementById('r-cap').hidden = !isCapped;

    var promoEl = document.getElementById('r-promo');
    var totWrap = document.getElementById('r-totreduc-wrap');
    var promoNote = document.getElementById('r-promo-note');
    if (PROMOS.length) {
      promoEl.hidden = false;
      document.getElementById('r-promo-lab').textContent = 'Promotion · ' + PROMOS.map(function(p){ return p.nom || p.promo_name || p.mirror_key; }).join(' + ');
      document.getElementById('r-promo-pct').textContent = '− ' + pct(promoRate);
      totWrap.hidden = false;
      document.getElementById('r-totreduc').textContent = '− ' + pct(totalRate);
      promoNote.hidden = false;
      promoNote.textContent = 'Promotion active appliquée automatiquement au paiement des frais — elle s\'ajoute au-delà du plafond de ' + pct(CAP) + '.';
    } else {
      promoEl.hidden = true; totWrap.hidden = true; promoNote.hidden = true;
    }

    document.getElementById('r-fixed').innerHTML = FIXES.map(function(f){
      return '<div class="r-line r-line--fixed"><span class="lab">' + esc(f.label) + '</span><span class="val">+ ' + fmt(f.v) + '</span></div>';
    }).join('');

    document.getElementById('r-total').textContent = totalDu === null ? '—' : fmt(Math.round(totalDu));
    document.getElementById('ab-pct').textContent = pct(totalRate);
    document.getElementById('ab-amt').textContent = totalDu === null ? '—' : fmt(Math.round(totalDu));

    var ids = applied.map(function(o){ return o.id; });
    history.replaceState(null, '', '?parcours=' + encodeURIComponent(ctx.parcours || '') +
      (ctx.session ? '&session=' + encodeURIComponent(ctx.session) : '') +
      (ids.length ? '&bourses=' + ids.join(',') : ''));

    var ctaLink = document.getElementById('cta-bourses-next');
    if (ctaLink) { ctaLink.href = AT.buildUrl('/identite', { bourses: ids.join(',') }); }
  }

  /* ---------- Modal ---------- */
  var modal = document.getElementById('modal');
  function openModal(id){
    var o = OPT[id]; if(!o) return;
    document.getElementById('modal-cat').textContent = o.catName;
    document.getElementById('modal-title').textContent = o.label;
    document.getElementById('modal-rate').textContent = '−' + pct(o.rate);
    document.getElementById('modal-desc').textContent = DESC_DEFAULT;
    document.getElementById('modal-ruletext').textContent = o.exclusive
      ? 'Bourse exclusive (groupe ' + o.group + ') : une seule bourse de ce groupe peut être retenue — la sélection remplace la précédente.'
      : 'Bourse cumulable avec les autres, dans la limite du plafond de ' + pct(CAP) + ' sur la scolarité.';
    modal.classList.add('show');
  }
  function closeModal(){ modal.classList.remove('show'); }
  document.getElementById('modal-close').addEventListener('click', closeModal);
  modal.addEventListener('click', function(e){ if(e.target === modal) closeModal(); });
  document.addEventListener('keydown', function(e){ if(e.key==='Escape') closeModal(); });

  /* ---------- Tabs ---------- */
  document.querySelectorAll('.tab-btn').forEach(function(btn){
    btn.addEventListener('click', function(){
      document.querySelectorAll('.tab-btn').forEach(function(b){ var on = b===btn; b.classList.toggle('is-active', on); b.setAttribute('aria-selected', on); });
      var t = btn.dataset.tab;
      document.getElementById('panel-select').classList.toggle('is-active', t==='select');
      document.getElementById('panel-paste').classList.toggle('is-active', t==='paste');
    });
  });

  /* ---------- Coller une simulation (ids = mirror_keys) ---------- */
  function applyFromIds(ids){
    Object.keys(selected).forEach(function(k){ selected[k] = null; });
    var ignored = [];
    ids.forEach(function(id){
      var o = OPT[id]; if(!o) return;
      var cur = selected[o.group];
      if(!cur){ selected[o.group] = id; }
      else if(o.rate > OPT[cur].rate){ ignored.push(OPT[cur]); selected[o.group] = id; }
      else { ignored.push(o); }
    });
    return ignored;
  }

  document.getElementById('paste-apply').addEventListener('click', function(){
    var raw = document.getElementById('paste-input').value.trim();
    var msg = document.getElementById('paste-msg');
    var txt = document.getElementById('paste-msg-text');
    msg.className = 'paste-msg';
    var mb = raw.match(/bourses=([A-Za-z0-9\-_,]+)/i);
    var ids = mb ? mb[1].split(',').map(function(s){ return s.trim(); }).filter(Boolean) : [];
    var known = ids.filter(function(id){ return OPT[id]; });
    if(!mb || known.length === 0){
      msg.classList.add('err','show');
      msg.querySelector('use').setAttribute('href', '#i-info');
      txt.innerHTML = "Lien non reconnu. Vérifiez qu'il contient bien <strong>?bourses=…</strong> avec des identifiants valides.";
      return;
    }
    var ignored = applyFromIds(known);
    var applied = known.length - ignored.length;
    render();
    document.querySelector('.tab-btn[data-tab="select"]').click();
    msg.classList.add('ok','show');
    msg.querySelector('use').setAttribute('href', '#i-checkcircle');
    var t = '<strong>Simulation appliquée.</strong> ' + applied + ' bourse' + (applied>1?'s':'') + ' pré-remplie' + (applied>1?'s':'') + '.';
    if(ignored.length){ t += ' ' + ignored.map(function(o){ return esc(o.label); }).join(', ') + ' ignorée' + (ignored.length>1?'s':'') + ' (exclusivité de groupe).'; }
    txt.innerHTML = t;
  });

  load();
})();
</script>


</TunnelLayout>
