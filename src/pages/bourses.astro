---
import TunnelLayout from '../layouts/TunnelLayout.astro';
import { getEntry } from 'astro:content';
const etape = await getEntry('etapes', 'bourses');
---
<TunnelLayout title="Candidature — Bourses d'études · Direction retenue">
<style is:global>

  body { background: var(--cream); -webkit-font-smoothing: antialiased; }
  [hidden] { display: none !important; }
  .ico { width: 18px; height: 18px; flex-shrink: 0; }
  .ico-sm { width: 15px; height: 15px; flex-shrink: 0; }
  .ico-lg { width: 22px; height: 22px; flex-shrink: 0; }

  /* ---- Progression ---- */
  .progress-strip { background: var(--surface-paper); border-bottom: 1px solid var(--border-subtle); }
  .progress-inner { max-width: 1120px; margin: 0 auto; padding: var(--space-4) var(--space-5); display: flex; align-items: center; gap: var(--space-6); }
  .progress-label { font-size: var(--text-sm); font-weight: 600; color: var(--text-primary); white-space: nowrap; }
  .progress-label .num { font-family: var(--font-mono); color: var(--violet); }
  .progress-seg { display: flex; gap: var(--space-3); flex: 1; max-width: 460px; }
  .seg { height: 5px; flex: 1; border-radius: 999px; background: var(--sand-200); }
  .seg.is-done { background: var(--violet); opacity: 0.45; }
  .seg.is-current { background: var(--violet); }
  .progress-steps-text { font-size: var(--text-sm); color: var(--text-tertiary); white-space: nowrap; display: none; }

  /* ---- Layout 2 colonnes ---- */
  .tunnel { max-width: 1120px; margin: 0 auto; padding: var(--space-8) var(--space-5); display: grid; grid-template-columns: 1fr; gap: var(--space-8); align-items: start; }

  /* Bloc d'ancrage violet + reçu */
  .lede { position: static; background: var(--violet); color: #fff; border-radius: var(--radius-xl); padding: var(--space-8) var(--space-7); }
  .lede-eyebrow { display: block; margin-bottom: var(--space-4); color: var(--gold); }
  .lede h1 { font-family: var(--font-display); font-size: var(--text-2xl); font-weight: 700; letter-spacing: -0.02em; line-height: 1.08; color: #fff; }
  .lede p { margin-top: var(--space-5); font-size: var(--text-base); color: rgba(255,255,255,0.80); text-wrap: pretty; }
  .lede-rules { margin-top: var(--space-6); display: flex; flex-direction: column; gap: var(--space-5); }
  .lede-rule { display: flex; gap: var(--space-3); align-items: flex-start; font-size: var(--text-sm); color: rgba(255,255,255,0.80); line-height: 1.45; }
  .lede-rule svg { color: var(--gold); flex-shrink: 0; margin-top: 1px; }
  .lede-rule strong { color: #fff; font-weight: 600; }

  /* Reçu chiffré */
  .receipt { margin-top: var(--space-7); padding-top: var(--space-6); border-top: 1px solid rgba(255,255,255,0.18); }
  .receipt-eyebrow { font-size: var(--text-2xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: rgba(255,255,255,0.62); margin-bottom: var(--space-4); }
  .r-line { display: flex; align-items: baseline; justify-content: space-between; gap: var(--space-4); font-size: var(--text-sm); padding: 5px 0; }
  .r-line .lab { color: rgba(255,255,255,0.78); }
  .r-line .val { font-family: var(--font-mono); color: #fff; font-variant-numeric: tabular-nums; white-space: nowrap; }
  .r-line--fixed { margin-top: 8px; }
  .r-line.minus .val { color: #FDE68A; }
  .r-line.muted { color: rgba(255,255,255,0.5); }
  .r-line.muted .lab, .r-line.muted .val { color: rgba(255,255,255,0.45); text-decoration: line-through; }
  .r-line.muted .tagi { text-decoration: none; font-size: var(--text-2xs); color: rgba(255,255,255,0.55); margin-left: 6px; }
  .r-empty { font-size: var(--text-sm); color: rgba(255,255,255,0.55); padding: 6px 0; font-style: italic; }
  .r-div { height: 1px; background: rgba(255,255,255,0.18); margin: var(--space-4) 0; }
  .r-reduc { display: flex; align-items: center; justify-content: space-between; gap: var(--space-3); }
  .r-reduc .lab { font-size: var(--text-sm); font-weight: 600; color: #fff; }
  .r-reduc .val { font-family: var(--font-display); font-size: var(--text-lg); font-weight: 700; color: var(--gold); }
  .cap-chip { display: inline-flex; align-items: center; gap: 5px; margin-top: var(--space-3); font-size: var(--text-2xs); font-weight: 700; padding: 3px 9px; border-radius: 999px; background: rgba(245,158,11,0.18); color: var(--gold); }
  .r-line.promo .val { color: #FDE68A; }
  .r-reduc-total { margin-top: var(--space-4); padding-top: var(--space-4); border-top: 1px dashed rgba(255,255,255,0.22); }
  .r-reduc-total .lab { color: #fff; font-weight: 700; }
  .r-reduc-total .val { color: var(--gold); font-family: var(--font-display); font-size: var(--text-lg); font-weight: 700; }
  .r-promo-note { margin-top: var(--space-3); font-size: var(--text-2xs); color: rgba(255,255,255,0.55); line-height: var(--leading-normal); }
  .r-total { margin-top: var(--space-5); padding-top: var(--space-5); border-top: 1px solid rgba(255,255,255,0.18); display: flex; align-items: flex-end; justify-content: space-between; gap: var(--space-4); }
  .r-total .lab { font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.08em; color: rgba(255,255,255,0.62); font-weight: 700; }
  .r-total .amt { font-family: var(--font-display); font-size: 30px; font-weight: 700; letter-spacing: -0.02em; color: #fff; line-height: 1; }
  .r-total .amt .cur { font-size: var(--text-sm); font-weight: 600; color: rgba(255,255,255,0.6); margin-left: 6px; }
  .r-foot { margin-top: var(--space-4); font-size: var(--text-xs); color: rgba(255,255,255,0.55); line-height: var(--leading-normal); }

  /* ---- Colonne droite ---- */
  .sec-kicker { font-size: var(--text-2xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-tertiary); display: flex; align-items: center; gap: var(--space-3); margin-bottom: var(--space-5); }
  .sec-kicker .n { width: 20px; height: 20px; border-radius: 50%; background: var(--violet); color: #fff; display: inline-flex; align-items: center; justify-content: center; font-family: var(--font-mono); font-size: 10px; }

  /* Tabs */
  .tabs { display: flex; background: var(--sable); border: 1px solid var(--border-default); border-radius: var(--radius-md); padding: 4px; gap: 4px; margin-bottom: var(--space-7); }
  .tab-btn { appearance: none; cursor: pointer; border: 0; background: transparent; font-family: var(--font-sans); font-size: var(--text-sm); font-weight: 600; color: var(--text-secondary); padding: 9px 18px; border-radius: var(--radius-sm); display: inline-flex; align-items: center; gap: var(--space-3); transition: all var(--duration-fast) var(--ease-out); flex: 1; justify-content: center; }
  .tab-btn svg { color: var(--text-tertiary); }
  .tab-btn:hover { color: var(--text-primary); }
  .tab-btn.is-active { background: var(--surface-paper); color: var(--violet); box-shadow: var(--shadow-xs); }
  .tab-btn.is-active svg { color: var(--violet); }

  .panel { display: none; }
  .panel.is-active { display: block; }

  /* Paste */
  .paste-card { background: var(--surface-paper); border: 1px solid var(--border-default); border-radius: var(--radius-lg); padding: var(--space-7); }
  .paste-card .pc-title { font-size: var(--text-base); font-weight: 600; color: var(--text-primary); }
  .paste-card .pc-sub { font-size: var(--text-sm); color: var(--text-secondary); margin-top: var(--space-2); line-height: var(--leading-normal); }
  .paste-input { margin-top: var(--space-5); width: 100%; min-height: 92px; resize: vertical; padding: var(--space-5); border: 1.5px solid var(--border-default); border-radius: var(--radius-md); background: var(--sable); font-family: var(--font-mono); font-size: var(--text-base); color: var(--text-primary); line-height: 1.6; }
  .paste-input::placeholder { color: var(--text-placeholder); }
  .paste-input:focus { outline: none; border-color: var(--violet); box-shadow: 0 0 0 3px var(--violet-soft); background: var(--surface-paper); }
  .paste-actions { margin-top: var(--space-5); display: flex; align-items: center; gap: var(--space-5); flex-wrap: wrap; }
  .paste-ex { font-size: var(--text-xs); color: var(--text-tertiary); }
  .paste-ex code { font-family: var(--font-mono); font-size: 11px; background: var(--sand-100); padding: 2px 6px; border-radius: var(--radius-xs); color: var(--text-secondary); }
  .paste-msg { margin-top: var(--space-5); display: none; gap: var(--space-3); align-items: flex-start; padding: var(--space-4) var(--space-5); border-radius: var(--radius-md); font-size: var(--text-sm); line-height: var(--leading-normal); }
  .paste-msg.show { display: flex; }
  .paste-msg.ok { background: var(--lagoon-soft); color: var(--lagoon-deep); }
  .paste-msg.ok svg { color: var(--lagoon); }
  .paste-msg.err { background: var(--error-50); color: var(--error-700); }
  .paste-msg.err svg { color: var(--error-500); }
  .paste-msg strong { font-weight: 700; }
  .paste-msg svg { flex-shrink: 0; margin-top: 1px; }

  /* Catégories de bourses */
  .cat { margin-bottom: var(--space-8); }
  .cat:last-child { margin-bottom: 0; }
  .cat-head { display: flex; align-items: center; gap: var(--space-4); margin-bottom: var(--space-4); }
  .cat-head > span:last-child { display: flex; flex-direction: column; }
  .cat-icon { width: 38px; height: 38px; border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .cat-icon.excellence { background: var(--gold); color: var(--gold-ink); }
  .cat-icon.partenaire { background: var(--lagoon-soft); color: var(--lagoon-deep); }
  .cat-icon.sociale { background: var(--clay-soft); color: var(--clay); }
  .cat-name { font-size: var(--text-md); font-weight: 700; color: var(--text-primary); display: block; }
  .cat-note { font-size: var(--text-xs); color: var(--text-tertiary); margin-top: 2px; display: block; }

  .opt-list { display: flex; flex-direction: column; gap: var(--space-3); }
  .opt { position: relative; display: flex; gap: var(--space-4); align-items: center; padding: var(--space-5); border: 1.5px solid var(--border-default); border-radius: var(--radius-md); background: var(--surface-paper); cursor: pointer; transition: border-color var(--duration-fast) var(--ease-out), box-shadow var(--duration-fast) var(--ease-out); }
  .opt:hover { border-color: var(--border-strong); }
  .opt .check { width: 22px; height: 22px; flex-shrink: 0; border: 1.5px solid var(--border-strong); border-radius: 50%; display: flex; align-items: center; justify-content: center; transition: all var(--duration-fast) var(--ease-out); }
  .opt .check svg { width: 12px; height: 12px; color: #fff; opacity: 0; transform: scale(0.6); transition: all var(--duration-fast) var(--ease-out); }
  .opt-body { flex: 1; min-width: 0; }
  .opt-name { font-size: var(--text-base); font-weight: 600; color: var(--text-primary); display: block; }
  .opt-badge { display: block; margin-top: 4px; font-size: var(--text-2xs); font-weight: 600; color: var(--text-tertiary); }
  .opt-rate { flex-shrink: 0; font-family: var(--font-display); font-size: var(--text-lg); font-weight: 700; letter-spacing: -0.01em; color: var(--violet); white-space: nowrap; }
  .q-btn { flex-shrink: 0; width: 26px; height: 26px; border-radius: 50%; border: 1.5px solid var(--border-default); background: var(--surface-paper); color: var(--text-tertiary); font-family: var(--font-display); font-weight: 700; font-size: 13px; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all var(--duration-fast) var(--ease-out); }
  .q-btn:hover { border-color: var(--violet); color: var(--violet); background: var(--violet-soft); }
  .opt.is-selected { border-color: var(--violet); background: var(--violet-soft); box-shadow: 0 0 0 1px var(--violet); }
  .opt.is-selected .check { background: var(--violet); border-color: var(--violet); }
  .opt.is-selected .check svg { opacity: 1; transform: scale(1); }

  /* Reçu mini dans la barre d'action */
  .action-bar { position: sticky; bottom: 0; z-index: var(--z-sticky); background: var(--surface-paper); border-top: 1px solid var(--border-default); box-shadow: 0 -8px 24px -16px rgba(15,14,10,0.18); }
  .action-bar-inner { max-width: 1120px; margin: 0 auto; padding: var(--space-4) var(--space-5); display: flex; align-items: center; justify-content: space-between; gap: var(--space-5); }
  .ab-left { display: flex; align-items: center; gap: var(--space-5); min-width: 0; }
  .back-link { display: inline-flex; align-items: center; gap: var(--space-2); font-size: var(--text-sm); color: var(--text-secondary); font-weight: 600; text-decoration: none; white-space: nowrap; }
  .back-link:hover { color: var(--violet); }
  .ab-recap { font-size: var(--text-sm); color: var(--text-secondary); white-space: nowrap; }
  .ab-recap strong { color: var(--violet); font-weight: 700; }
  .ab-recap .amt { color: var(--text-primary); font-weight: 700; font-family: var(--font-display); }
  .ab-recap { display: none; }
  .em-btn--lg { flex: 1; }
  .back-link span { display: none; }

  /* CTA or */
  .em-btn--primary { background: var(--gold); color: var(--gold-ink); }
  .em-btn--primary:hover { background: var(--gold-deep); color: var(--gold-ink); }
  .em-btn--primary:active { background: var(--gold-deep); }

  /* Modal info */
  .modal-scrim { position: fixed; inset: 0; z-index: var(--z-modal); background: var(--surface-overlay); display: none; align-items: center; justify-content: center; padding: var(--space-6); }
  .modal-scrim.show { display: flex; }
  .modal { width: 100%; max-width: 460px; background: var(--surface-paper); border-radius: var(--radius-xl); box-shadow: var(--shadow-xl); overflow: hidden; }
  .modal-head { display: flex; align-items: flex-start; gap: var(--space-4); padding: var(--space-7) var(--space-7) var(--space-5); }
  .modal-cat { font-size: var(--text-2xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--violet); }
  .modal-title { font-family: var(--font-display); font-size: var(--text-xl); font-weight: 700; letter-spacing: -0.01em; color: var(--text-primary); margin-top: var(--space-2); }
  .modal-rate { margin-left: auto; flex-shrink: 0; font-family: var(--font-display); font-size: var(--text-2xl); font-weight: 700; color: var(--violet); }
  .modal-close { position: absolute; top: 14px; right: 14px; width: 34px; height: 34px; border-radius: 50%; border: 0; background: var(--sand-100); color: var(--text-secondary); cursor: pointer; display: flex; align-items: center; justify-content: center; }
  .modal-close:hover { background: var(--sand-200); color: var(--text-primary); }
  .modal-body { padding: 0 var(--space-7) var(--space-6); }
  .modal-body p { font-size: var(--text-base); color: var(--text-secondary); line-height: var(--leading-relaxed); }
  .modal-rule { margin: var(--space-6) var(--space-7) var(--space-7); padding: var(--space-5); background: var(--violet-soft); border-radius: var(--radius-md); display: flex; gap: var(--space-3); align-items: flex-start; }
  .modal-rule svg { color: var(--violet); flex-shrink: 0; margin-top: 1px; }
  .modal-rule p { font-size: var(--text-sm); color: var(--violet-deep); line-height: var(--leading-normal); }
  .modal { position: relative; }

  /* ---- Media queries mobile-first ---- */
  @media (min-width: 480px) {
    .progress-steps-text { display: block; }
    .progress-inner { padding: var(--space-4) var(--space-8); }
    .action-bar-inner { padding: var(--space-5) var(--space-8); }
    .em-btn--lg { flex: initial; }
    .back-link span { display: inline; }
    .tabs { display: inline-flex; }
    .tab-btn { flex: initial; justify-content: initial; }
  }

  @media (min-width: 768px) {
    .tunnel { grid-template-columns: 360px 1fr; gap: var(--space-11); padding: var(--space-10) var(--space-8); }
    .lede { position: sticky; top: 120px; padding: var(--space-9) var(--space-8) var(--space-8); }
    .lede h1 { font-size: var(--text-3xl); }
    .ab-recap { display: inline; }
  }

</style>


