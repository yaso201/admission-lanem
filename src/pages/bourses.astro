<main class="tunnel" id="main">
  <!-- Colonne éditoriale gauche + reçu live -->
  <aside class="lede">
    <span class="t-overline lede-eyebrow">{etape.data.eyebrow}</span>
    <h1>{etape.data.titre}</h1>
    <p>{etape.data.description}</p>
    <div class="lede-rules">
      {etape.data.points.map(pt => (
        <div class="lede-rule">
          <svg class="ico"><use href={`#${pt.icon}`}/></svg>
          <span>{pt.detail}</span>
        </div>
      ))}
    </div>

    <div class="receipt" aria-live="polite">
      <div class="receipt-eyebrow">Estimation — <span id="r-parcours">votre formation</span></div>
      <div class="r-line"><span class="lab">Scolarité annuelle</span><span class="val" id="r-base">…</span></div>
      <div id="r-lines"></div>
      <div class="r-div"></div>
      <div class="r-reduc"><span class="lab">Bourses retenues</span><span class="val" id="r-reduc-pct">0 %</span></div>
      <div id="r-cap" class="cap-chip" hidden><svg class="ico-sm"><use href="#i-shield"/></svg><span id="r-cap-text">Plafonnée</span></div>
      <div class="r-line promo" id="r-promo" hidden><span class="lab" id="r-promo-lab">Promotion</span><span class="val" id="r-promo-pct">− 10 %</span></div>
      <div class="r-reduc r-reduc-total" id="r-totreduc-wrap" hidden><span class="lab">Réduction totale</span><span class="val" id="r-totreduc">− 0 %</span></div>
      <p class="r-promo-note" id="r-promo-note" hidden></p>
      <div id="r-fixed"></div>
      <div class="r-total">
        <span class="lab">À prévoir / an</span>
        <span class="amt"><span id="r-total">…</span><span class="cur">FCFA</span></span>
      </div>
      <p class="r-foot">Les bourses s'appliquent sur la scolarité uniquement. Les frais fixes ne sont jamais réduits.</p>
    </div>
  </aside>

  <!-- Colonne droite : choix -->
  <div>
    <div class="sec-kicker"><span class="n">1</span>Vos bourses</div>

    <div class="tabs" role="tablist">
      <button type="button" class="tab-btn is-active" data-tab="select" role="tab" aria-selected="true"><svg class="ico-sm"><use href="#i-list"/></svg>Choisir mes bourses</button>
      <button type="button" class="tab-btn" data-tab="paste" role="tab" aria-selected="false"><svg class="ico-sm"><use href="#i-clipboard"/></svg>Coller ma simulation</button>
    </div>

    <!-- Panneau : coller -->
    <div class="panel" id="panel-paste" role="tabpanel">
      <div class="paste-card">
        <div class="pc-title">Déjà fait une simulation&nbsp;?</div>
        <div class="pc-sub">Collez le lien généré par le simulateur de bourses. Nous pré-remplissons vos choix automatiquement.</div>
        <label for="paste-input" class="sr-only">Lien de simulation à coller</label>
        <textarea class="paste-input" id="paste-input" placeholder="Collez ici votre lien de simulation…
ex : https://esiia.fr/simulateur?parcours=licence&bourses=tres-bien,partenaire-20"></textarea>
        <div class="paste-actions">
          <button type="button" class="em-btn em-btn--primary" id="paste-apply">Appliquer la simulation</button>
          <span class="paste-ex">Format reconnu&nbsp;: <code>?parcours=…&amp;bourses=…</code></span>
        </div>
        <div class="paste-msg" id="paste-msg"><svg class="ico"><use href="#i-checkcircle"/></svg><span id="paste-msg-text"></span></div>
      </div>
    </div>

    <!-- Panneau : choisir -->
    <div class="panel is-active" id="panel-select" role="tabpanel">
      <div id="cats"></div>
    </div>
  </div>
</main>

