<script is:inline src="/scripts/admission-tunnel.js"></script>
<script is:inline src="/scripts/admission-profil.js"></script>
<script is:inline>
(function () {
  'use strict';
  var AT = window.AdmissionTunnel;
  var AP = window.AdmissionProfil;
  var ctx = AT.readCtx();

  var el = {
    prenom: document.getElementById('prenom'),
    nom: document.getElementById('nom'),
    email: document.getElementById('email'),
    tel: document.getElementById('tel'),
    niveau: document.getElementById('niveau'),
    datebac: document.getElementById('datebac'),
    consentDp: document.getElementById('consent-dp'),
    consentCgv: document.getElementById('consent-cgv'),
    formMsg: document.getElementById('form-msg'),
    cta: document.getElementById('cta-identite'),
    gateText: document.getElementById('ab-gate-text'),
    back: document.getElementById('back-identite'),
    otpDest: document.getElementById('otp-dest'),
    telDest: document.getElementById('tel-dest'),
    otpBadge: document.getElementById('otp-badge'),
    otpBody: document.getElementById('otp-body'),
    otpVerify: document.getElementById('otp-verify'),
    otpResendWait: document.getElementById('otp-resend-wait'),
    otpResend: document.getElementById('otp-resend'),
    otpTimer: document.getElementById('otp-timer'),
    otpMsg: document.getElementById('otp-msg')
  };
  var digits = Array.prototype.slice.call(document.querySelectorAll('.otp-digit'));

  /* Retour dynamique */
  el.back.href = AT.buildUrl(ctx.bourse === 'oui' ? '/bourses' : '/');

  /* ---- Profil bac indicatif (DEC-214) — le back classifie à la création ---- */
  var card = document.getElementById('bac-result');
  function renderBac() {
    var profil = AP.classer(el.datebac.value);
    if (!profil) { card.hidden = true; return; }
    card.hidden = false;
    card.classList.toggle('is-conditionnel', !!profil.conditionnel);
    document.getElementById('bac-label').textContent = profil.label;
    var badge = document.getElementById('bac-badge');
    if (profil.conditionnel) {
      badge.hidden = false;
      badge.className = 'em-badge em-badge--warning';
      badge.textContent = 'Admission conditionnelle';
    } else { badge.hidden = true; }
    document.getElementById('bac-resume').textContent = profil.resume;
    document.getElementById('bac-conseq').textContent = profil.consequence;
    var req = AP.piecesPour(profil).filter(function (p) { return p.requis; }).length;
    document.getElementById('bac-pieces').textContent =
      req + ' pièce' + (req > 1 ? 's' : '') + ' obligatoire' + (req > 1 ? 's' : '') + ' pour ce profil — détail à l’étape Pièces.';
    AP.save({ value: el.datebac.value, override: null, profil: profil.id });
  }
  el.datebac.addEventListener('input', function () { renderBac(); refreshGate(); });

  /* ---- Niveau d'entrée : niveaux RÉELS du programme de la session ---- */
  function setNiveauOptions(list, placeholder) {
    /* Options construites en DOM (textContent) — données catalogue jamais injectées en HTML. */
    el.niveau.textContent = '';
    var first = document.createElement('option');
    first.value = '';
    first.textContent = placeholder;
    el.niveau.appendChild(first);
    (list || []).forEach(function (n) {
      var opt = document.createElement('option');
      opt.value = n.level_code;
      opt.textContent = n.level_name;
      el.niveau.appendChild(opt);
    });
  }
  function loadNiveaux() {
    AT.api.listSessions(null, function (resS) {
      var sessions = (resS.ok && resS.data && resS.data.sessions) || [];
      var current = null;
      for (var i = 0; i < sessions.length; i++) {
        if (sessions[i].id === ctx.session) { current = sessions[i]; break; }
      }
      if (!current) {
        setNiveauOptions([], 'Session introuvable — repartez de l’accueil');
        return;
      }
      AT.api.listProgrammes(function (resP) {
        var progs = (resP.ok && resP.data && resP.data.programmes) || [];
        var niveaux = [];
        for (var j = 0; j < progs.length; j++) {
          if (progs[j].code === current.programme.code) { niveaux = progs[j].niveaux || []; break; }
        }
        if (!niveaux.length) {
          setNiveauOptions([], 'Aucun niveau disponible');
          return;
        }
        setNiveauOptions(niveaux, 'Choisissez votre niveau…');
        if (niveaux.length === 1) { el.niveau.value = niveaux[0].level_code; }
        refreshGate();
      });
    });
  }

  /* ---- Validation + gate ---- */
  function formValid() {
    var emailOk = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(el.email.value.trim());
    var telOk = (el.tel.value.replace(/[^0-9+]/g, '').length >= 8);
    return el.prenom.value.trim() && el.nom.value.trim() && emailOk && telOk &&
      el.niveau.value && el.datebac.value && el.consentDp.checked && el.consentCgv.checked;
  }
  var phase = 'form';
  function refreshGate() {
    if (phase !== 'form') { return; }
    if (formValid()) {
      el.cta.removeAttribute('disabled');
      el.cta.setAttribute('aria-disabled', 'false');
      el.gateText.textContent = 'Prêt — un code vous sera envoyé par e-mail';
    } else {
      el.cta.setAttribute('disabled', '');
      el.cta.setAttribute('aria-disabled', 'true');
      el.gateText.textContent = 'Renseignez vos informations et consentements';
    }
  }
  ['input', 'change'].forEach(function (evt) {
    [el.prenom, el.nom, el.email, el.tel, el.niveau, el.consentDp, el.consentCgv].forEach(function (f) {
      f.addEventListener(evt, refreshGate);
    });
  });
  el.email.addEventListener('input', function () { el.otpDest.textContent = el.email.value.trim() || '—'; });
  el.tel.addEventListener('input', function () { el.telDest.textContent = el.tel.value.trim() || '—'; });

  function showFormError(message) {
    el.formMsg.className = 'form-msg is-error';
    el.formMsg.textContent = message;
  }

  /* ---- Phase OTP ---- */
  var resendLeft = 0, resendTick = null;
  function startResendTimer(seconds) {
    resendLeft = seconds;
    el.otpResendWait.hidden = false;
    el.otpResend.hidden = true;
    clearInterval(resendTick);
    resendTick = setInterval(function () {
      resendLeft -= 1;
      var m = Math.floor(resendLeft / 60), s = resendLeft % 60;
      el.otpTimer.textContent = m + ':' + (s < 10 ? '0' : '') + s;
      if (resendLeft <= 0) {
        clearInterval(resendTick);
        el.otpResendWait.hidden = true;
        el.otpResend.hidden = false;
      }
    }, 1000);
    el.otpTimer.textContent = Math.floor(seconds / 60) + ':' + (seconds % 60 < 10 ? '0' : '') + (seconds % 60);
  }

  function otpMessage(kind, text) {
    el.otpMsg.className = 'otp-msg' + (kind ? ' is-' + kind : '');
    el.otpMsg.textContent = text || '';
  }

  function enterOtpPhase(sent) {
    phase = 'otp';
    [el.prenom, el.nom, el.email, el.tel, el.niveau, el.datebac].forEach(function (f) { f.setAttribute('readonly', ''); });
    el.niveau.setAttribute('disabled', '');
    el.consentDp.setAttribute('disabled', '');
    el.consentCgv.setAttribute('disabled', '');
    el.otpBody.hidden = false;
    el.otpBadge.hidden = false;
    el.otpBadge.className = 'em-badge em-badge--warning';
    el.otpBadge.textContent = sent ? 'Code envoyé' : 'En attente du code';
    el.cta.setAttribute('disabled', '');
    el.cta.setAttribute('aria-disabled', 'true');
    el.cta.innerHTML = 'Saisissez le code reçu par e-mail';
    el.gateText.textContent = 'Vérifiez votre e-mail pour continuer';
    if (sent) { startResendTimer(60); }
    else { el.otpResendWait.hidden = true; el.otpResend.hidden = false; }
    if (digits[0]) { digits[0].focus(); }
  }

  function requestCode(cb) {
    AT.api.requestOtp(function (res) {
      if (res.ok) {
        otpMessage('ok', 'Code envoyé à ' + el.otpDest.textContent + '.');
        startResendTimer(60);
      } else {
        otpMessage('error', (res.error && res.error.message) || 'Envoi du code impossible. Réessayez.');
        el.otpResendWait.hidden = true;
        el.otpResend.hidden = false;
      }
      if (cb) { cb(res); }
    });
  }

  el.otpResend.addEventListener('click', function () {
    otpMessage('', '');
    requestCode();
  });

  el.otpVerify.addEventListener('click', function () {
    var code = digits.map(function (d) { return d.value; }).join('');
    if (code.length !== 6) {
      otpMessage('error', 'Saisissez les 6 chiffres du code.');
      return;
    }
    el.otpVerify.setAttribute('disabled', '');
    otpMessage('', 'Vérification…');
    AT.api.verifyOtp('email', code, function (res) {
      el.otpVerify.removeAttribute('disabled');
      if (res.ok) {
        otpMessage('ok', 'Adresse vérifiée. Redirection vers les pièces…');
        el.otpBadge.className = 'em-badge em-badge--success';
        el.otpBadge.textContent = 'Vérifié';
        var profil = (AP.load() || {}).profil || '';
        AT.navigateTo('/pieces', { profil: profil });
      } else {
        var codeErr = res.error && res.error.code;
        if (codeErr === 'OTP_EXPIRED') {
          otpMessage('error', 'Code expiré. Demandez un nouveau code ci-dessous.');
          el.otpResendWait.hidden = true;
          el.otpResend.hidden = false;
        } else {
          otpMessage('error', (res.error && res.error.message) || 'Code invalide. Vérifiez et réessayez.');
        }
        digits.forEach(function (d) { d.value = ''; d.classList.remove('is-filled'); });
        if (digits[0]) { digits[0].focus(); }
      }
    });
  });

  /* ---- Création du dossier (F1 : payload RÉEL) ---- */
  el.cta.addEventListener('click', function () {
    if (phase !== 'form' || !formValid()) { return; }
    el.cta.setAttribute('disabled', '');
    el.cta.textContent = 'Création du dossier…';
    el.formMsg.textContent = '';
    var payload = {
      session: ctx.session,
      level_code: el.niveau.value,
      identite: {
        prenom: el.prenom.value.trim(),
        nom: el.nom.value.trim(),
        email: el.email.value.trim(),
        tel: el.tel.value.trim(),
        date_bac: el.datebac.value ? el.datebac.value + '-01' : null
      },
      consent_data_processing: el.consentDp.checked,
      consent_cgv: el.consentCgv.checked,
      bourses_demandees: ctx.bourses ? ctx.bourses.split(',').filter(Boolean) : []
    };
    AT.api.createDossier(payload, function (res) {
      if (res.ok) {
        requestCode(function () { enterOtpPhase(true); });
      } else {
        el.cta.removeAttribute('disabled');
        el.cta.innerHTML = 'Réessayer<svg class="ico"><use href="#i-caretright"/></svg>';
        showFormError((res.error && res.error.message) || 'Erreur lors de la création du dossier. Réessayez.');
      }
    });
  });

  /* ---- Reprise sur la page (dossier déjà créé dans cette session) ---- */
  if (AT.getDossierId() && AT.getDossierToken()) {
    el.otpDest.textContent = 'votre adresse e-mail';
    enterOtpPhase(false);
    otpMessage('', 'Un dossier est déjà en cours. Demandez un code pour continuer.');
  } else {
    loadNiveaux();
  }
  renderBac();
  refreshGate();
})();
</script>

<script is:inline>
/* M4 — Auto-navigation OTP digits (avant + backspace) */
(function () {
  var digits = Array.prototype.slice.call(document.querySelectorAll('.otp-digit'));
  if (!digits.length) return;

  digits.forEach(function (el, i) {
    el.addEventListener('input', function () {
      el.value = el.value.replace(/[^0-9]/g, '').slice(0, 1);
      if (el.value && i < digits.length - 1) {
        digits[i + 1].focus();
      }
      /* Met à jour les classes visuelles */
      digits.forEach(function (d) {
        d.classList.toggle('is-filled', !!d.value);
        d.classList.remove('is-cursor');
      });
      if (document.activeElement && document.activeElement.classList.contains('otp-digit')) {
        document.activeElement.classList.add('is-cursor');
      }
    });

    el.addEventListener('keydown', function (e) {
      if (e.key === 'Backspace' && !el.value && i > 0) {
        e.preventDefault();
        digits[i - 1].value = '';
        digits[i - 1].focus();
        digits[i - 1].classList.remove('is-filled');
      }
    });

    el.addEventListener('focus', function () {
      digits.forEach(function (d) { d.classList.remove('is-cursor'); });
      el.classList.add('is-cursor');
    });

    /* Coller le code complet d'un coup */
    el.addEventListener('paste', function (e) {
      var text = (e.clipboardData || window.clipboardData).getData('text') || '';
      var nums = text.replace(/[^0-9]/g, '').slice(0, digits.length);
      if (nums.length > 1) {
        e.preventDefault();
        digits.forEach(function (d, j) {
          d.value = nums[j] || '';
          d.classList.toggle('is-filled', !!d.value);
        });
        var next = Math.min(nums.length, digits.length - 1);
        digits[next].focus();
      }
    });
  });
})();
</script>

