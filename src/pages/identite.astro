---
import TunnelLayout from '../layouts/TunnelLayout.astro';
import { getEntry } from 'astro:content';
const etape = await getEntry('etapes', 'identite');
---
<TunnelLayout title="Candidature — Identité & vérification · Étape 2">
<style is:global>

  body { background: var(--cream); -webkit-font-smoothing: antialiased; }
  .ico { width: 18px; height: 18px; flex-shrink: 0; }
  .ico-sm { width: 15px; height: 15px; flex-shrink: 0; }
  .ico-lg { width: 22px; height: 22px; flex-shrink: 0; }

  /* Progress */
  .progress-strip { background: var(--surface-paper); border-bottom: 1px solid var(--border-subtle); }
  .progress-inner { max-width: 1120px; margin: 0 auto; padding: var(--space-4) var(--space-5); display: flex; align-items: center; gap: var(--space-6); }
  .progress-label { font-size: var(--text-sm); font-weight: 600; color: var(--text-primary); white-space: nowrap; }
  .progress-label .num { font-family: var(--font-mono); color: var(--violet); }
  .progress-seg { display: flex; gap: var(--space-3); flex: 1; max-width: 420px; }
  .seg { height: 5px; flex: 1; border-radius: 999px; background: var(--sand-200); }
  .seg.is-done { background: var(--violet); }
  .seg.is-current { background: var(--violet); }
  .progress-steps-text { font-size: var(--text-sm); color: var(--text-tertiary); white-space: nowrap; display: none; }

  /* Layout */
  .tunnel { max-width: 1120px; margin: 0 auto; padding: var(--space-8) var(--space-5); display: grid; grid-template-columns: 1fr; gap: var(--space-8); align-items: start; }

  /* Anchor block */
  .lede { position: static; background: var(--violet); color: #fff; border-radius: var(--radius-xl); padding: var(--space-8) var(--space-7); }
  .lede-eyebrow { display: block; margin-bottom: var(--space-4); color: var(--gold); }
  .lede h1 { font-family: var(--font-display); font-size: var(--text-2xl); font-weight: 700; letter-spacing: -0.02em; line-height: 1.08; color: #fff; }
  .lede p { margin-top: var(--space-5); font-size: var(--text-md); color: rgba(255,255,255,0.80); text-wrap: pretty; }
  .lede-points { margin-top: var(--space-7); display: flex; flex-direction: column; gap: var(--space-5); padding-top: var(--space-6); border-top: 1px solid rgba(255,255,255,0.16); }
  .lede-point { display: flex; gap: var(--space-4); align-items: flex-start; font-size: var(--text-sm); color: rgba(255,255,255,0.74); }
  .lede-point svg { color: var(--gold); flex-shrink: 0; margin-top: 1px; }
  .lede-point strong { color: #fff; font-weight: 600; display: block; }

  /* Section heads */
  .sec { margin-bottom: var(--space-9); }
  .sec:last-child { margin-bottom: 0; }
  .sec-kicker { font-size: var(--text-2xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-tertiary); display: flex; align-items: center; gap: var(--space-3); margin-bottom: var(--space-5); }
  .sec-kicker .n { width: 20px; height: 20px; border-radius: 50%; background: var(--violet); color: #fff; display: inline-flex; align-items: center; justify-content: center; font-family: var(--font-mono); font-size: 10px; }

  /* Fields grid */
  .field-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-5); }
  .field-grid .col-full { grid-column: 1 / -1; }

  /* OTP block */
  .otp-stack { display: flex; flex-direction: column; gap: var(--space-4); }
  .otp-channel { border: 1px solid var(--border-default); border-radius: var(--radius-md); background: var(--surface-paper); overflow: hidden; }
  .otp-head { display: flex; align-items: center; gap: var(--space-4); padding: var(--space-5) var(--space-6); }
  .otp-ic { width: 40px; height: 40px; border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .otp-ic--done { background: var(--lagoon-soft); color: var(--lagoon-deep); }
  .otp-ic--active { background: var(--violet-soft); color: var(--violet); }
  .otp-head-body { flex: 1; min-width: 0; }
  .otp-channel-label { font-size: var(--text-2xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-tertiary); }
  .otp-dest { font-size: var(--text-base); font-weight: 600; color: var(--text-primary); display: flex; align-items: center; gap: var(--space-3); flex-wrap: wrap; }
  .otp-body { padding: 0 var(--space-6) var(--space-6); border-top: 1px solid var(--border-subtle); padding-top: var(--space-5); }
  .otp-body[hidden] { display: none; }
  .otp-instr { font-size: var(--text-sm); color: var(--text-secondary); margin-bottom: var(--space-5); }
  .otp-digits { display: flex; gap: var(--space-3); margin-bottom: var(--space-5); }
  .otp-digit {
    width: 44px; height: 52px; text-align: center;
    font-family: var(--font-mono); font-size: var(--text-lg); font-weight: 600; color: var(--text-primary);
    border: 1.5px solid var(--border-default); border-radius: var(--radius-sm); background: var(--surface-paper);
    transition: border-color var(--duration-fast) var(--ease-out), box-shadow var(--duration-fast) var(--ease-out);
  }
  .otp-digit.is-filled { border-color: var(--violet); }
  .otp-digit.is-cursor { border-color: var(--violet); box-shadow: var(--shadow-focus); }
  .otp-actions { display: flex; align-items: center; gap: var(--space-5); flex-wrap: wrap; }
  .otp-resend { font-size: var(--text-sm); color: var(--text-tertiary); display: inline-flex; align-items: center; gap: var(--space-2); }
  .otp-resend .t { font-variant-numeric: tabular-nums; font-weight: 600; color: var(--text-secondary); }
  .otp-resend-link { appearance: none; border: 0; background: none; cursor: pointer; font-family: var(--font-sans); font-size: var(--text-sm); font-weight: 600; color: var(--text-link); text-decoration: underline; text-underline-offset: 2px; padding: 0; }
  .otp-msg { margin-top: var(--space-4); font-size: var(--text-sm); }
  .otp-msg.is-error { color: var(--terra, #B3261E); }
  .otp-msg.is-ok { color: var(--lagoon-deep); }

  /* Consentements */
  .consent-box { border: 1px solid var(--border-default); border-radius: var(--radius-md); background: var(--surface-paper); padding: var(--space-5) var(--space-6); display: flex; flex-direction: column; gap: var(--space-4); }
  .consent-row { display: flex; gap: var(--space-4); align-items: flex-start; font-size: var(--text-sm); color: var(--text-secondary); line-height: var(--leading-normal); }
  .consent-row input[type="checkbox"] { width: 18px; height: 18px; margin-top: 1px; flex-shrink: 0; accent-color: var(--violet); }
  .consent-row a { color: var(--text-link); text-decoration: underline; text-underline-offset: 2px; }

  /* Erreur formulaire */
  .form-msg { margin-top: var(--space-5); font-size: var(--text-sm); }
  .form-msg.is-error { color: var(--terra, #B3261E); }

  /* Action bar */
  .action-bar { position: sticky; bottom: 0; z-index: var(--z-sticky); background: var(--surface-paper); border-top: 1px solid var(--border-default); box-shadow: 0 -8px 24px -16px rgba(15,14,10,0.18); }
  .action-bar-inner { max-width: 1120px; margin: 0 auto; padding: var(--space-4) var(--space-5); display: flex; align-items: center; justify-content: space-between; gap: var(--space-4); }
  .ab-left { display: flex; align-items: center; gap: var(--space-5); min-width: 0; }
  .ab-gate { font-size: var(--text-sm); color: var(--text-secondary); display: none; align-items: center; gap: var(--space-3); }
  .ab-gate svg { color: var(--violet); flex-shrink: 0; }
  .ab-right { display: flex; align-items: center; gap: var(--space-4); flex: 1; }
  .ab-right .em-btn--lg { flex: 1; }

  /* CTA or + overrides palette */
  .em-btn--primary { background: var(--gold); color: var(--gold-ink); }
  .em-btn--primary:hover { background: var(--gold-deep); color: var(--gold-ink); }
  .em-btn--primary[disabled] { background: var(--gold); color: var(--gold-ink); }
  .em-badge--success { background: var(--lagoon-soft); color: var(--lagoon-deep); }
  .em-badge--success .em-badge-dot { background: var(--lagoon); }
  .em-badge--warning { background: #FBEBD8; color: var(--accent-900); }

  /* Bloc baccalauréat + profil calculé (DEC-214) */
  .bac-field-head { display: flex; align-items: baseline; justify-content: space-between; gap: var(--space-4); flex-wrap: wrap; }

  .bac-result { margin-top: var(--space-5); border: 1.5px solid var(--border-default); border-radius: var(--radius-lg); background: var(--surface-paper); padding: var(--space-6); display: flex; flex-direction: column; gap: var(--space-4); }
  .bac-result[hidden] { display: none; }
  .bac-result.is-conditionnel { border-color: var(--gold); background: var(--accent-50); }
  .bac-result-top { display: flex; align-items: center; gap: var(--space-4); }
  .bac-result-ic { width: 38px; height: 38px; border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center; flex-shrink: 0; background: var(--violet-soft); color: var(--violet); }
  .bac-result.is-conditionnel .bac-result-ic { background: #FBEBD8; color: var(--ochre); }
  .bac-result-head { flex: 1; min-width: 0; }
  .bac-result-kicker { font-size: var(--text-2xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-tertiary); }
  .bac-result-label { font-size: var(--text-md); font-weight: 700; color: var(--text-primary); margin-top: 1px; display: flex; align-items: center; gap: var(--space-3); flex-wrap: wrap; }
  .em-badge[hidden] { display: none !important; }
  .bac-result-resume { font-size: var(--text-sm); color: var(--text-secondary); line-height: var(--leading-normal); }
  .bac-result-conseq { display: flex; gap: var(--space-3); align-items: flex-start; font-size: var(--text-sm); color: var(--text-primary); line-height: var(--leading-normal); padding-top: var(--space-4); border-top: 1px solid var(--border-subtle); }
  .bac-result.is-conditionnel .bac-result-conseq { border-top-color: #F1DDBF; }
  .bac-result-conseq svg { flex-shrink: 0; margin-top: 2px; color: var(--violet); }
  .bac-result.is-conditionnel .bac-result-conseq svg { color: var(--ochre); }
  .bac-result-pieces { font-size: var(--text-xs); color: var(--text-tertiary); display: flex; align-items: center; gap: var(--space-3); }
  .bac-result-pieces svg { color: var(--text-tertiary); flex-shrink: 0; }

  /* ---- Media queries mobile-first ---- */
  @media (min-width: 480px) {
    .progress-steps-text { display: block; }
    .progress-inner { padding: var(--space-4) var(--space-8); }
    .action-bar-inner { padding: var(--space-5) var(--space-8); gap: var(--space-5); }
    .ab-right { flex: initial; }
    .ab-right .em-btn--lg { flex: initial; }
    .field-grid { grid-template-columns: 1fr 1fr; }
    .otp-digit { width: 48px; height: 56px; font-size: var(--text-xl); }
  }

  @media (min-width: 768px) {
    .tunnel { grid-template-columns: 340px 1fr; gap: var(--space-11); padding: var(--space-10) var(--space-8); }
    .lede { position: sticky; top: 120px; padding: var(--space-9) var(--space-8); }
    .lede h1 { font-size: var(--text-3xl); }
    .ab-gate { display: inline-flex; }
  }

</style>


