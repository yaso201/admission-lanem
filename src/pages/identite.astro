</svg>

<div class="progress-strip">
  <div class="progress-inner">
    <span class="progress-label"><span class="num">2</span> / 4 — Identité</span>
    <div class="progress-seg" role="progressbar" aria-valuenow="2" aria-valuemin="0" aria-valuemax="4" aria-label="Étape 2 sur 4 : Identité">
      <span class="seg is-done"></span>
      <span class="seg is-current"></span>
      <span class="seg"></span>
      <span class="seg"></span>
    </div>
    <span class="progress-steps-text">Suivant&nbsp;: Pièces · Récapitulatif</span>
  </div>
</div>

<main class="tunnel" id="main">
  <!-- Anchor block -->
  <aside class="lede">
    <span class="t-overline lede-eyebrow">{etape.data.eyebrow}</span>
    <h1>{etape.data.titre}</h1>
    <p>{etape.data.description}</p>
    <div class="lede-points">
      {etape.data.points.map(pt => (
        <div class="lede-point">
          <svg class="ico-lg"><use href={`#${pt.icon}`}/></svg>
          <span><strong>{pt.titre}</strong>{pt.detail}</span>
        </div>
      ))}
    </div>
  </aside>

  <!-- Form column -->
  <div>
    <!-- Identity fields -->
    <div class="sec">
      <div class="sec-kicker"><span class="n">1</span>Votre identité</div>
      <div class="field-grid">
        <div class="em-field">
          <label class="em-field-label" for="prenom">Prénom <span class="em-required" aria-hidden="true">*</span></label>
          <input type="text" class="em-input" id="prenom" autocomplete="given-name" required />
        </div>
        <div class="em-field">
          <label class="em-field-label" for="nom">Nom <span class="em-required" aria-hidden="true">*</span></label>
          <input type="text" class="em-input" id="nom" autocomplete="family-name" required />
        </div>
        <div class="em-field col-full">
          <label class="em-field-label" for="email">Email <span class="em-required" aria-hidden="true">*</span></label>
          <input class="em-input" id="email" type="email" inputmode="email" autocomplete="email" required />
          <span class="em-field-help">Le code de vérification et la décision d'admission seront envoyés à cette adresse.</span>
        </div>
        <div class="em-field col-full">
          <label class="em-field-label" for="tel">Téléphone mobile <span class="em-required" aria-hidden="true">*</span></label>
          <input class="em-input" id="tel" type="tel" inputmode="tel" autocomplete="tel" placeholder="+229…" required />
          <span class="em-field-help">Utilisé par le service des admissions pour vous joindre (relances, contact).</span>
        </div>
        <div class="em-field col-full">
          <label class="em-field-label" for="niveau">Niveau d'entrée <span class="em-required" aria-hidden="true">*</span></label>
          <select class="em-input" id="niveau" required>
            <option value="">Chargement des niveaux…</option>
          </select>
          <span class="em-field-help">Niveau auquel vous candidatez dans ce programme.</span>
        </div>
        <div class="em-field col-full">
          <div class="bac-field-head">
            <label class="em-field-label" for="datebac">Date d'obtention du Bac <span class="em-required" aria-hidden="true">*</span></label>
          </div>
          <input class="em-input" id="datebac" type="month" aria-describedby="bac-result" required />
          <span class="em-field-help">Mois et année de votre session du baccalauréat. Votre profil — et les pièces à fournir — en découlent automatiquement.</span>
        </div>
      </div>

      <!-- Profil calculé (DEC-214) — indicatif : le back fait foi à la création -->
      <div class="bac-result" id="bac-result" aria-live="polite" hidden>
        <div class="bac-result-top">
          <span class="bac-result-ic" id="bac-ic"><svg class="ico-lg"><use href="#i-cap"/></svg></span>
          <span class="bac-result-head">
            <span class="bac-result-kicker">Profil de candidature</span>
            <span class="bac-result-label"><span id="bac-label"></span><span class="em-badge" id="bac-badge" hidden></span></span>
          </span>
        </div>
        <span class="bac-result-resume" id="bac-resume"></span>
        <span class="bac-result-conseq"><svg class="ico-sm"><use href="#i-info"/></svg><span id="bac-conseq"></span></span>
        <span class="bac-result-pieces"><svg class="ico-sm"><use href="#i-files"/></svg><span id="bac-pieces"></span></span>
      </div>
    </div>

    <!-- Consentements (requis par le back : CONSENT_REQUIRED) -->
    <div class="sec">
      <div class="sec-kicker"><span class="n">2</span>Consentements</div>
      <div class="consent-box">
        <label class="consent-row">
          <input type="checkbox" id="consent-dp" />
          <span>J'accepte que mes données personnelles soient traitées dans le cadre de ma candidature, conformément à la <a href="/legal/politique-de-confidentialite" target="_blank" rel="noopener">politique de confidentialité</a>. <span class="em-required" aria-hidden="true">*</span></span>
        </label>
        <label class="consent-row">
          <input type="checkbox" id="consent-cgv" />
          <span>J'ai lu et j'accepte les <a href="/legal/cgv" target="_blank" rel="noopener">conditions générales</a> de candidature. <span class="em-required" aria-hidden="true">*</span></span>
        </label>
      </div>
      <div class="form-msg" id="form-msg" role="alert" aria-live="polite"></div>
    </div>

    <!-- Vérification OTP (LOT F / A0.1 : le code est livré par E-MAIL) -->
    <div class="sec">
      <div class="sec-kicker"><span class="n">3</span>Vérification de votre adresse e-mail</div>
      <div class="otp-stack">

        <!-- Email — canal porteur du code -->
        <div class="otp-channel">
          <div class="otp-head">
            <span class="otp-ic otp-ic--active"><svg class="ico-lg"><use href="#i-envelope"/></svg></span>
            <span class="otp-head-body">
              <span class="otp-channel-label">Adresse email</span>
              <span class="otp-dest" id="otp-dest">—</span>
            </span>
            <span class="em-badge" id="otp-badge" hidden></span>
          </div>
          <div class="otp-body" id="otp-body" hidden>
            <p class="otp-instr">Saisissez le code à 6 chiffres reçu par e-mail. Pensez à vérifier vos courriers indésirables.</p>
            <div class="otp-digits" role="group" aria-label="Code de vérification à 6 chiffres">
              <input type="text" class="otp-digit" inputmode="numeric" pattern="[0-9]*" autocomplete="one-time-code" maxlength="1" aria-label="Chiffre 1" />
              <input type="text" class="otp-digit" inputmode="numeric" pattern="[0-9]*" autocomplete="one-time-code" maxlength="1" aria-label="Chiffre 2" />
              <input type="text" class="otp-digit" inputmode="numeric" pattern="[0-9]*" autocomplete="one-time-code" maxlength="1" aria-label="Chiffre 3" />
              <input type="text" class="otp-digit" inputmode="numeric" pattern="[0-9]*" autocomplete="one-time-code" maxlength="1" aria-label="Chiffre 4" />
              <input type="text" class="otp-digit" inputmode="numeric" pattern="[0-9]*" autocomplete="one-time-code" maxlength="1" aria-label="Chiffre 5" />
              <input type="text" class="otp-digit" inputmode="numeric" pattern="[0-9]*" autocomplete="one-time-code" maxlength="1" aria-label="Chiffre 6" />
            </div>
            <div class="otp-actions">
              <button type="button" class="em-btn em-btn--secondary" id="otp-verify">Vérifier le code</button>
              <span class="otp-resend" id="otp-resend-wait" hidden><svg class="ico-sm"><use href="#i-info"/></svg>Renvoyer le code dans <span class="t" id="otp-timer">1:00</span></span>
              <button type="button" class="otp-resend-link" id="otp-resend" hidden>Renvoyer le code</button>
            </div>
            <div class="otp-msg" id="otp-msg" role="status" aria-live="polite"></div>
          </div>
        </div>

        <!-- Téléphone — collecté pour le contact humain (A0.1), pas de code SMS -->
        <div class="otp-channel">
          <div class="otp-head">
            <span class="otp-ic otp-ic--done"><svg class="ico-lg"><use href="#i-phone"/></svg></span>
            <span class="otp-head-body">
              <span class="otp-channel-label">Téléphone mobile</span>
              <span class="otp-dest" id="tel-dest">—</span>
            </span>
            <span class="em-badge">Contact</span>
          </div>
        </div>

      </div>
    </div>
  </div>
</main>

<div class="action-bar">
  <div class="action-bar-inner">
    <div class="ab-left">
      <a class="em-btn em-btn--ghost" id="back-identite" href="/"><svg class="ico"><use href="#i-caretleft"/></svg>Retour</a>
      <span class="ab-gate" id="ab-gate"><svg class="ico-sm"><use href="#i-lock"/></svg><span id="ab-gate-text">Renseignez vos informations et consentements</span></span>
    </div>
    <div class="ab-right">
      <button type="button" class="em-btn em-btn--primary em-btn--lg" id="cta-identite" disabled aria-disabled="true">Créer mon dossier<svg class="ico"><use href="#i-caretright"/></svg></button>
    </div>
  </div>
